---
import '../styles/global.css';
import { UI, localeFromPath, basePath } from '../i18n/ui.js';

const { title, description, noindex = false } = Astro.props;
const phone = '+13102995555';
const phoneDisplay = '(310) 299-5555';
const site = 'https://www.covertoday.com';

const pathname = Astro.url.pathname;
const lang = localeFromPath(pathname);
const bp = basePath(pathname);
const t = UI[lang];

const enHref = bp;
// RU switcher: only link to RU pages that actually exist.
// EN-only pages (blog articles, about, careers, 404) fall back to the closest RU page.
const EN_ONLY = ['/about', '/careers', '/404'];
const ruHref = bp === '/' ? '/ru/'
  : bp.startsWith('/resources/') ? '/ru/resources'
  : EN_ONLY.includes(bp) ? '/ru/'
  : '/ru' + bp;
const homeHref = lang === 'en' ? '/' : '/' + lang + '/';
const canonical = site + pathname;
const ogLocale = lang === 'ru' ? 'ru_RU' : lang === 'es' ? 'es_ES' : 'en_US';
const schema = {
  "@context": "https://schema.org",
  "@type": "InsuranceAgency",
  "name": "CoverToday Insurance Agency",
  "@id": site + "/#org",
  "url": site,
  "image": site + "/og.png",
  "logo": site + "/og.png",
  "telephone": "+13102995555",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "272 S Rampart Blvd",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90057",
    "addressCountry": "US"
  },
  "areaServed": ["California", "Texas", "Illinois", "Arizona", "Nevada", "North Carolina", "Washington"],
  "knowsLanguage": ["en", "ru"],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"], "opens": "09:00", "closes": "18:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "17:00" }
  ],
  "sameAs": [
    "https://www.yelp.com/biz/cover-today-insurance-los-angeles",
    "https://www.facebook.com/people/Cover-Today-Insurance-Agency/61570850433880/",
    "https://www.youtube.com/@CoverTodayInsurance"
  ]
};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="alternate" hreflang="en" href={site + enHref} />
  <link rel="alternate" hreflang="ru" href={site + ruHref} />
  <link rel="alternate" hreflang="x-default" href={site + enHref} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#0a4ba0" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CoverToday Insurance" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={site + '/og.png'} />
  <meta property="og:locale" content={ogLocale} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={site + '/og.png'} />
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-5D272LH2');</script>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}></script>
</head>
<body>
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5D272LH2" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <div class="topbar"><div class="wrap">
    <span>{t.topbar}</span>
    <span class="langs">
      <a href={enHref} class={lang === 'en' ? 'active' : ''}>EN</a>
      <a href={ruHref} class={lang === 'ru' ? 'active' : ''}>RU</a>
    </span>
  </div></div>

  <header class="site-header"><div class="wrap">
    <a class="brand" href={homeHref} aria-label="CoverToday Insurance Agency — home">
      <svg class="shield" viewBox="0 0 44 50" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M22 2 L40 8 V24 C40 36 32.5 44.5 22 48 C11.5 44.5 4 36 4 24 V8 Z" fill="#0a4ba0"/>
        <path d="M6.5 30 C9.5 38 15 43.5 22 47.6 C18.4 43 15.9 38 15.4 32.4 C20.6 31.4 26.2 28.4 31.2 24 C22 22.4 13 24 6.5 30 Z" fill="#ff5a1f"/>
        <path d="M6 27 C13 22 23 21 33.5 24.2" stroke="#ffffff" stroke-width="1.7" stroke-linecap="round" fill="none" opacity="0.95"/>
      </svg>
      <span class="brand-text">
        <span class="bt-name"><span class="bt-cover">Cover</span><span class="bt-today">Today</span></span>
        <span class="bt-sub">Insurance Agency</span>
      </span>
    </a>
    <nav class="nav-links">
      {t.nav.map((n) => (
        n.children ? (
          <div class="nav-group">
            <a href={n.href}>{n.label} <span class="caret">▾</span></a>
            <div class="submenu">{n.children.map((c) => (<a href={c.href}>{c.label}</a>))}</div>
          </div>
        ) : (<a href={n.href}>{n.label}</a>)
      ))}
    </nav>
    <div class="header-cta">
      <a class="btn btn-ghost" href={lang === 'en' ? '/quote' : '/' + lang + '/quote'}>{t.getQuote}</a>
      <a class="btn btn-call" href={`tel:${phone}`}>📞 {phoneDisplay}</a>
    </div>
    <button class="hamburger" aria-label="Open menu" aria-expanded="false" onclick="ctToggleMenu()"><span></span><span></span><span></span></button>
  </div></header>

  <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
    <div class="mm-top">
      <span class="brand-text"><span class="bt-name"><span class="bt-cover">Cover</span><span class="bt-today">Today</span></span><span class="bt-sub">Insurance Agency</span></span>
      <button class="mm-close" aria-label="Close menu" onclick="ctToggleMenu()">✕</button>
    </div>
    <div class="mm-body">
      {t.nav.map((n) => (
        n.children ? (
          <div class="mm-group"><div class="mm-head">{n.label}</div>{n.children.map((c) => (<a href={c.href}>{c.label}</a>))}</div>
        ) : (<a class="mm-link" href={n.href}>{n.label}</a>)
      ))}
      <div class="mm-cta">
        <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {phoneDisplay}</a>
        <a class="btn btn-text btn-lg" href={lang === 'en' ? '/quote' : '/' + lang + '/quote'}>{t.getFreeQuote}</a>
      </div>
    </div>
  </div>

  <slot />

  <section class="ctaband"><div class="wrap">
    <h2>{t.ctaTitle}</h2>
    <p>{t.ctaSub}</p>
    <div class="ctas">
      <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {phoneDisplay}</a>
      <a class="btn btn-text btn-lg" href={`sms:${phone}`}>💬 {t.textUs}</a>
    </div>
  </div></section>

  <footer class="site-footer"><div class="wrap">
    <div>© 2026 CoverToday Insurance Agency · DOI License #0K77310<br/>CoverToday Insurance Agency is a DBA of Univision Insurance Services LLC<br/>272 S Rampart Blvd, Los Angeles, CA 90057 · info@covertoday.com</div>
    <div><a href={`tel:${phone}`}>{phoneDisplay}</a> · <a href={lang === 'en' ? '/contact' : '/' + lang + '/contact'}>{t.footerContact}</a> · <a href={lang === 'en' ? '/privacy-policy' : '/' + lang + '/privacy-policy'}>{t.footerPrivacy}</a> · <a href={lang === 'en' ? '/sms-terms' : '/' + lang + '/sms-terms'}>SMS Terms</a></div>
  </div></footer>

  <div class="sticky">
    <a class="btn btn-call" href={`tel:${phone}`}>📞 {t.call}</a>
    <a class="btn btn-text" href={`sms:${phone}`}>💬 {t.text}</a>
  </div>

  <!-- HighLevel (LeadConnector) chat widget — replaced Telegram fab 2026-07-02.
       Not rendered on quote pages: A2P compliance requires the widget to be the only SMS opt-in method on pages where it's embedded, and quote pages have their own consent forms. -->
  {!Astro.url.pathname.includes('/quote') && (
    <script is:inline src="https://widgets.leadconnectorhq.com/loader.js" data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js" data-widget-id="6a4ea04a318b99a1e9711bb1" data-source="WEB_USER"></script>
  )}

  <script is:inline>
    document.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('a[href^="tel:"],a[href^="sms:"]');
      if (!a) return;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'generate_lead', lead_type: a.getAttribute('href').indexOf('sms:') === 0 ? 'text' : 'call' });
    });
  </script>
  <script is:inline>
    function ctToggleMenu(){var m=document.getElementById('mobileMenu');var b=document.querySelector('.hamburger');var o=m.classList.toggle('open');if(b){b.classList.toggle('is-open',o);b.setAttribute('aria-expanded',o);}m.setAttribute('aria-hidden',!o);document.body.style.overflow=o?'hidden':'';}
  </script>
</body>
</html>
