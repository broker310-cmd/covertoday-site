---
import '../styles/global.css';
import { UI, localeFromPath, basePath } from '../i18n/ui.js';

const { title, description } = Astro.props;
const phone = '+13102995555';
const phoneDisplay = '(310) 299-5555';
const site = 'https://www.covertoday.com';

const pathname = Astro.url.pathname;
const lang = localeFromPath(pathname);
const bp = basePath(pathname);
const t = UI[lang];

const enHref = bp;
const ruHref = bp === '/' ? '/ru/' : '/ru' + bp;
const esHref = bp === '/' ? '/es/' : '/es' + bp;
const homeHref = lang === 'en' ? '/' : '/' + lang + '/';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="alternate" hreflang="en" href={site + enHref} />
  <link rel="alternate" hreflang="ru" href={site + ruHref} />
  <link rel="alternate" hreflang="es" href={site + esHref} />
  <link rel="alternate" hreflang="x-default" href={site + enHref} />
</head>
<body>
  <div class="topbar"><div class="wrap">
    <span>{t.topbar}</span>
    <span class="langs">
      <a href={enHref} class={lang === 'en' ? 'active' : ''}>EN</a>
      <a href={ruHref} class={lang === 'ru' ? 'active' : ''}>RU</a>
      <a href={esHref} class={lang === 'es' ? 'active' : ''}>ES</a>
    </span>
  </div></div>

  <header class="site-header"><div class="wrap">
    <a class="brand" href={homeHref}>
      <svg class="shield" viewBox="0 0 30 34" fill="none"><path d="M15 1l13 4v11c0 9-5.6 14.5-13 17C7.6 31.5 2 26 2 16V5l13-4z" fill="#0a4ba0"/><path d="M9 16.5l4 4 8-8" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      CoverToday
    </a>
    <nav class="nav-links">
      {t.nav.map((n) => (<a href={n.href}>{n.label}</a>))}
    </nav>
    <div class="header-cta">
      <a class="btn btn-ghost" href={lang === 'en' ? '/quote' : '/' + lang + '/quote'}>{t.getQuote}</a>
      <a class="btn btn-call" href={`tel:${phone}`}>📞 {phoneDisplay}</a>
    </div>
  </div></header>

  <slot />

  <section class="ctaband"><div class="wrap">
    <h2>{t.ctaTitle}</h2>
    <p>{t.ctaSub}</p>
    <div class="ctas">
      <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {phoneDisplay}</a>
      <a class="btn btn-text btn-lg" href={`sms:${phone}`}>💬 {t.textUs}</a>
    </div>
  </div></section>

  <footer class="site-footer"><div class="wrap">
    <div>© 2026 CoverToday Insurance Agency · DOI License #0K77310<br/>272 S Rampart Blvd, Los Angeles, CA 90057</div>
    <div><a href={`tel:${phone}`}>{phoneDisplay}</a> · <a href={lang === 'en' ? '/contact' : '/' + lang + '/contact'}>{t.footerContact}</a> · <a href={lang === 'en' ? '/privacy-policy' : '/' + lang + '/privacy-policy'}>{t.footerPrivacy}</a></div>
  </div></footer>

  <div class="sticky">
    <a class="btn btn-call" href={`tel:${phone}`}>📞 {t.call}</a>
    <a class="btn btn-text" href={`sms:${phone}`}>💬 {t.text}</a>
  </div>
</body>
</html>
