---
import '../styles/global.css';
const { title, description, lang = 'en' } = Astro.props;
const phone = '+13102995555';
const phoneDisplay = '(310) 299-5555';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <!-- Top bar -->
  <div class="topbar"><div class="wrap">
    <span>DOI License #0K77310 · Licensed CA broker since 2013 · Serving CA, TX, IL, AZ, NV, NC, WA</span>
    <span class="langs">
      <a href="/" class={lang === 'en' ? 'active' : ''}>EN</a>
      <a href="/ru/" class={lang === 'ru' ? 'active' : ''}>RU</a>
      <a href="/es/" class={lang === 'es' ? 'active' : ''}>ES</a>
    </span>
  </div></div>

  <!-- Header -->
  <header class="site-header"><div class="wrap">
    <a class="brand" href="/">
      <svg class="shield" viewBox="0 0 30 34" fill="none"><path d="M15 1l13 4v11c0 9-5.6 14.5-13 17C7.6 31.5 2 26 2 16V5l13-4z" fill="#0a4ba0"/><path d="M9 16.5l4 4 8-8" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      CoverToday
    </a>
    <nav class="nav-links">
      <a href="/auto-insurance">Auto</a>
      <a href="/sr22-insurance">SR-22</a>
      <a href="/commercial-truck-insurance">Trucking / DOT-MC</a>
      <a href="/business-insurance">Business</a>
      <a href="/resources">Resources</a>
      <a href="/contact">Contact</a>
    </nav>
    <div class="header-cta">
      <a class="btn btn-ghost" href="/quote">Get Quote</a>
      <a class="btn btn-call" href={`tel:${phone}`}>📞 {phoneDisplay}</a>
    </div>
  </div></header>

  <slot />

  <!-- CTA band -->
  <section class="ctaband"><div class="wrap">
    <h2>Talk to a licensed agent today</h2>
    <p>Russian-speaking · English · Español. No pressure, no spam — just your best rate.</p>
    <div class="ctas">
      <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {phoneDisplay}</a>
      <a class="btn btn-text btn-lg" href={`sms:${phone}`}>💬 Text us</a>
    </div>
  </div></section>

  <!-- Footer -->
  <footer class="site-footer"><div class="wrap">
    <div>© 2026 CoverToday Insurance Agency · DOI License #0K77310<br/>272 S Rampart Blvd, Los Angeles, CA 90057</div>
    <div><a href={`tel:${phone}`}>{phoneDisplay}</a> · <a href="/contact">Contact</a> · <a href="/privacy-policy">Privacy</a></div>
  </div></footer>

  <!-- Sticky mobile bar -->
  <div class="sticky">
    <a class="btn btn-call" href={`tel:${phone}`}>📞 Call</a>
    <a class="btn btn-text" href={`sms:${phone}`}>💬 Text</a>
  </div>
</body>
</html>
