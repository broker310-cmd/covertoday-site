---
import Base from '../layouts/Base.astro';
const phone = '+13102995555';
const faqs = [
  { q: 'How fast can you file my SR-22?', a: 'Usually the same day you start a policy with us — often within the hour.' },
  { q: 'How much does SR-22 cost in California?', a: 'The filing fee is small (about $25). Your premium depends on your record — we compare 40+ carriers to find your lowest rate.' },
  { q: 'How long do I need an SR-22?', a: 'In California, typically 3 years. We remind you before it expires so your coverage never lapses.' },
  { q: 'Can I get one after a DUI or with a suspended license?', a: 'Yes — those are the most common reasons our clients need an SR-22.' },
  { q: 'Do you offer non-owner SR-22?', a: 'Yes — if you need an SR-22 but don’t own a vehicle, we can file a non-owner policy.' },
];
---
<Base
  title="SR-22 Insurance — Same-Day DMV Filing | CoverToday (CA & multi-state)"
  description="Need an SR-22? CoverToday files same-day with the DMV and compares 40+ carriers for your lowest rate. DUI & suspended-license OK. Russian-speaking agents. Call (310) 299-5555.">

  <section class="hero"><div class="wrap">
    <h1>Need an SR-22? We file it today.</h1>
    <p class="sub">Same-day SR-22 filing with the DMV. We compare 40+ carriers to get you back on the road for less. DUI, lapse, or suspended license — we specialize in it. Мы говорим по-русски.</p>
    <div class="ctas">
      <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 Call (310) 299-5555</a>
      <a class="btn btn-text btn-lg" href={`sms:${phone}`}>💬 Text us</a>
    </div>
    <div class="reassure">
      <span><span class="tick">✓</span> Same-day filing</span>
      <span><span class="tick">✓</span> DUI / suspended license OK</span>
      <span><span class="tick">✓</span> Non-owner SR-22 available</span>
    </div>
  </div></section>

  <div class="trust"><div class="wrap">
    <span class="item">🏆 5.0 ★ Yelp</span>
    <span class="item">⚡ Filed within the hour</span>
    <span class="item">🤝 40+ carriers</span>
    <span class="item">🇷🇺 Russian-speaking</span>
  </div></div>

  <section><div class="wrap" style="max-width:820px">
    <div class="eyebrow">The basics</div>
    <h2 class="sec">What is an SR-22?</h2>
    <p class="lead">An SR-22 isn’t insurance — it’s a certificate your insurer files with the DMV to prove you carry the state’s required liability coverage. You usually need one after a DUI, driving uninsured, or a license suspension. We handle the filing and the policy together, so you’re covered and compliant the same day.</p>
  </div></section>

  <section class="soft"><div class="wrap">
    <div class="eyebrow">Simple process</div>
    <h2 class="sec">How it works</h2>
    <div class="grid grid-3">
      <div class="card"><div class="ic">1</div><h3>Call or get a quote</h3><p>Tell us why you need the SR-22 — 2 minutes, no pressure.</p></div>
      <div class="card"><div class="ic">2</div><h3>We find your best rate</h3><p>We compare 40+ carriers, including ones that specialize in high-risk drivers.</p></div>
      <div class="card"><div class="ic">3</div><h3>We file it same-day</h3><p>Your SR-22 goes to the DMV and you’re back on the road.</p></div>
    </div>
  </div></section>

  <section><div class="wrap" style="max-width:820px">
    <div class="eyebrow">FAQ</div>
    <h2 class="sec">SR-22 questions, answered</h2>
    <div style="margin-top:22px">
      {faqs.map((f) => (
        <details class="card" style="margin-bottom:12px">
          <summary style="font-weight:700;font-size:17px;cursor:pointer">{f.q}</summary>
          <p style="margin-top:10px">{f.a}</p>
        </details>
      ))}
    </div>
  </div></section>

</Base>
