---
import Base from '../layouts/Base.astro';

const faqs = [
  { q: 'How much does it cost to start a trucking company?', a: 'The FMCSA operating authority fee is $300 per authority. But the real cost is insurance: a new authority typically buys $1M auto liability plus $100K cargo, and first-year premiums are the highest you will ever pay — carriers price new DOT numbers cautiously. With clean inspections and no claims, renewals improve significantly. Get insurance quotes before you file anything.' },
  { q: 'How long does it take to get my authority active?', a: 'Plan on several weeks: the authority itself has a protest/vetting period, and it will not activate until your insurer files proof of coverage (BMC-91/91X). Critical: proof of insurance must be on file within 90 days of applying or the application is dismissed and you start over. Line up insurance before or at the same time as your application.' },
  { q: 'Do I need an MC number if I only haul inside California?', a: 'No — interstate for-hire authority (the MC docket) is for crossing state lines. Purely intrastate California carriers instead need a CA Motor Carrier Permit (CA number) through the DMV, with insurance proof filed by your insurer. You still need a USDOT number if your vehicle is over 10,001 lbs GVWR. Household-goods movers have a separate regime (BHGS/MTR permit).' },
  { q: 'What insurance will brokers and shippers require?', a: 'The federal minimum for general freight over 10,001 lbs is $750,000 liability, but in practice nearly every broker and shipper requires $1,000,000 liability and $100,000 motor truck cargo before they will load you. Amazon Relay and intermodal (UIIA) work have their own specific requirements — we handle those filings daily.' },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};

const steps = [
  { n: '1', t: 'Set up the business', d: 'Form your entity (LLC is most common), get an EIN from the IRS, open a business bank account. Decide now whether you’ll run under your own authority or lease onto an existing carrier — it changes everything below.' },
  { n: '2', t: 'Get your CDL (if you’re driving)', d: 'Class A CDL through a licensed school; expect ELDT (entry-level driver training) requirements. Owner-operators who hire drivers instead skip to the compliance side.' },
  { n: '3', t: 'USDOT number — via FMCSA’s Motus system', d: 'Register in FMCSA’s Motus portal (the modernized registration system). Required for commercial vehicles over 10,001 lbs GVWR even if you never leave California.' },
  { n: '4', t: 'Operating authority (MC docket) — if interstate for-hire', d: '$300 per authority via Motus. New docket numbers are randomized now, and each new authority gets its own docket. Authority does NOT activate until insurance is filed.' },
  { n: '5', t: 'Insurance — start this FIRST, not last', d: 'The 90-day trap: proof of insurance must be on file within 90 days of applying, or the application is dismissed. Your insurer files BMC-91/91X liability ($750K federal minimum for general freight; $1M is the market standard brokers demand), plus $100K cargo, physical damage if financed, and NTL/bobtail if leased-on. Quotes before paperwork.' },
  { n: '6', t: 'BOC-3 process agents', d: 'Designate process agents in every state (one blanket filing through an agency). Required before authority is granted.' },
  { n: '7', t: 'UCR — Unified Carrier Registration', d: 'Annual registration based on fleet size. Quick, cheap, and forgotten by half of new carriers until the roadside check.' },
  { n: '8', t: 'IRP plates + IFTA fuel account', d: 'Apportioned plates (IRP) and the fuel-tax agreement (IFTA) through CA DMV/CDTFA for interstate operation. Quarterly IFTA filings from day one — keep fuel receipts.' },
  { n: '9', t: 'California intrastate: Motor Carrier Permit', d: 'Hauling for hire inside California requires the CA MCP (CA number) from DMV, with proof of insurance filed by your insurer. Household-goods movers are different: BHGS/MTR permit with TL 676 / TL 672 filings — not the old Cal-T.' },
  { n: '10', t: 'CARB Clean Truck Check', d: 'Diesel trucks over 14,000 lbs operating in California must be registered in CARB’s Clean Truck Check program: annual compliance fee plus periodic emissions testing. Non-compliance blocks DMV registration.' },
  { n: '11', t: 'Drug & alcohol program + Clearinghouse', d: 'Pre-employment drug test before any CDL driver (including you) drives, enrollment in a random testing consortium, FMCSA Clearinghouse registration, and annual driver queries.' },
  { n: '12', t: 'ELD, HOS and the New Entrant audit', d: 'Registered ELD in the truck, hours-of-service compliance, driver qualification files, and vehicle maintenance records — FMCSA’s New Entrant Safety Audit comes within your first 12 months. Clean CSA scores are also what bring your insurance renewal down.' },
];
---
<Base
  title="How to Start a Trucking Company in California — 2026 Checklist | CoverToday"
  description="The 12-step checklist: USDOT & MC via Motus, the 90-day insurance trap, BOC-3, UCR, IRP/IFTA, CA Motor Carrier Permit, CARB Clean Truck Check, Clearinghouse, ELD and the New Entrant audit. EN & RU."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <section class="hero"><div class="wrap">
    <h1>From zero to <span style="color:var(--accent)">your own authority.</span></h1>
    <p class="sub">The 12-step checklist for starting a trucking company in California in 2026 — in the right order, including the 90-day insurance trap that kills applications.</p>
  </div></section>

  <section><div class="wrap guide">

    {steps.map(s => (
      <div class="gstep">
        <div class="gnum">{s.n}</div>
        <div>
          <h2>{s.t}</h2>
          <p>{s.d}</p>
        </div>
      </div>
    ))}

    <div class="gcard">
      <h2>After launch: where the money actually is</h2>
      <p>Loads come from brokers, load boards, and direct shippers — and all of them check your insurance and CSA record before anything else. <strong>Amazon Relay</strong> and intermodal/port work (<strong>UIIA</strong>) each have their own insurance requirements beyond the standard $1M/$100K. Run clean for the first year: your <strong>insurance renewal</strong> is priced off your inspections and claims, and the drop from year-one pricing is where owner-operators finally start keeping money.</p>
      <p>Deep dives on our blog: <a href="/resources/mc-numbers-in-2026-fmcsa-motus-registration-and-insurance-explained">MC numbers &amp; Motus in 2026</a> · <a href="/resources/how-much-does-commercial-truck-insurance-cost-in-california-2026">what truck insurance costs in 2026</a> · <a href="/resources/commercial-trucking-insurance-in-california-dot-mc-owner-operator-guide">the owner-operator insurance guide</a>.</p>
    </div>

    <div class="gcard gcta">
      <h3>Trucking insurance is our specialty.</h3>
      <p>New authorities, owner-operators, fleets — we quote 15+ trucking markets, file your BMC-91/91X and CA filings, and issue same-day COIs. In English and Russian.</p>
      <a class="btn btn-call btn-lg" href="/quote">Get a trucking quote</a>
      <p class="gphone">(310) 299-5555 · covertoday.com/quote</p>
    </div>

    <h2 class="sec" style="font-size:24px">Frequently asked questions</h2>
    {faqs.map(f => (
      <details class="gfaq"><summary>{f.q}</summary><p>{f.a}</p></details>
    ))}

    <p class="gdisc">Educational checklist, not legal advice — requirements depend on your operation; verify with FMCSA, CA DMV, and CARB. Independent broker — we compare multiple carriers; coverage, eligibility, price and availability vary and may not be available to everyone. Related: <a href="/commercial-truck-insurance">commercial truck insurance</a> · <a href="/cargo-van-sprinter-insurance">cargo van &amp; sprinter</a>.</p>

  </div></section>
</Base>

<style is:global>
  .guide{max-width:820px;padding-bottom:40px}
  .gstep{display:flex;gap:16px;background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:22px 24px;margin-bottom:12px}
  .gnum{flex:0 0 40px;height:40px;border-radius:12px;background:var(--blue);color:#fff;font-weight:800;font-size:18px;display:flex;align-items:center;justify-content:center}
  .gstep h2{font-size:18px;margin-bottom:4px}
  .gstep p{margin:0;color:var(--muted);font-size:15px;line-height:1.6}
  .gcard{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:26px 28px;margin:18px 0}
  .gcard h2{font-size:21px;margin-bottom:12px}
  .gcard p{margin:10px 0;color:var(--ink)}
  .gcard a{color:var(--blue);font-weight:600}
  .gcta{background:var(--blue-dark);color:#fff;text-align:center;padding:34px 28px}
  .gcta h3{color:#fff;font-size:23px}
  .gcta p{color:#fff;opacity:.88;max-width:560px;margin:10px auto 18px}
  .gphone{margin-top:14px !important;font-size:14px !important}
  .gfaq{background:#fff;border:1px solid var(--line);border-radius:14px;margin-bottom:8px;padding:0 18px}
  .gfaq summary{padding:14px 0;cursor:pointer;font-weight:700}
  .gfaq p{padding:0 0 16px;color:var(--muted)}
  .gdisc{color:var(--muted);font-size:13px;margin:24px 0 10px}
  .gdisc a{color:var(--blue)}
</style>
