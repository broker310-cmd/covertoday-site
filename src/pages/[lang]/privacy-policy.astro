---
import Base from '../../layouts/Base.astro';
import { privacy } from '../../i18n/content-standalone.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'ru' }, props: { c: privacy.ru } },
  ];
}
const { c } = Astro.props;
---
<Base title={c.metaTitle} description={c.metaDesc}>
  <section style="padding-top:48px"><div class="wrap" style="max-width:780px">
    <h1 style="font-size:34px">{c.h1}</h1>
    <p class="lead" style="margin-top:14px">{c.lead}</p>
    <div style="margin-top:24px;color:var(--muted);font-size:16px;line-height:1.7" set:html={c.body}></div>
  </div></section>
</Base>
