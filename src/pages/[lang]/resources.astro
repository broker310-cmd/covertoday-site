---
import Base from '../../layouts/Base.astro';
import { resources } from '../../i18n/content-standalone.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'ru' }, props: { c: resources.ru } },
  ];
}
const { c } = Astro.props;
---
<Base title={c.metaTitle} description={c.metaDesc}>
  <section class="hero"><div class="wrap">
    <h1>{c.h1}</h1>
    <p class="sub">{c.sub}</p>
  </div></section>
  <section><div class="wrap">
    {c.tools && (
      <>
        <div class="eyebrow">{c.toolsEyebrow}</div>
        <h2 class="sec">{c.toolsTitle}</h2>
        <div class="grid grid-3" style="margin-bottom:40px">
          {c.tools.map((tl) => (<a class="card" href={tl.href}><div class="eyebrow" style="margin-bottom:6px">{tl.k}</div><h3>{tl.t}</h3><p>{tl.d}</p></a>))}
        </div>
      </>
    )}
    <div class="eyebrow">{c.eyebrow}</div>
    <h2 class="sec">{c.title}</h2>
    <div class="grid grid-3">
      {c.topics.map((tp) => (<div class="card"><h3>{tp.t}</h3><p>{tp.d}</p></div>))}
    </div>
    <p class="lead" style="margin-top:24px" set:html={c.cta}></p>
  </div></section>
</Base>
