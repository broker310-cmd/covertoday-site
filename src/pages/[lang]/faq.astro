---
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }];
}
const phone = '+13102995555';

// Гибридный FAQ-хаб: статические ответы для SEO + кнопки «Спросить ИИ»,
// открывающие чат-виджет GoHighLevel (window.leadConnector.chatWidget.openWidget()).
const cats = [
  {
    id: 'quotes',
    icon: '⚡',
    name: 'Котировки и как мы работаем',
    faqs: [
      { q: 'Как получить котировку и сколько это стоит?', a: 'Котировки всегда бесплатны и занимают несколько минут. Три способа: спросите ИИ-ассистента в окне чата (справа внизу), позвоните или напишите SMS на (310) 299-5555, либо заполните <a href="/ru/quote">онлайн-форму</a>. Лицензированный агент свяжется с вами в тот же день с реальными цифрами от надёжных страховых компаний.' },
      { q: 'Какая информация нужна для точной котировки?', a: 'Меньше, чем вы думаете — котировка это бесплатная оценка, и ничего не обязательно. Для авто: год/марка/модель (или VIN), ваш возраст, ZIP-код и стаж вождения (опыт из любой страны учитывается). Расскажите что можете — остальное агент уточнит по телефону.' },
      { q: 'Вы страховая компания или брокер?', a: 'Мы независимые брокеры, лицензированы с 2013 года (лицензия Калифорнии #0K77310). Мы работаем на вас, а не на одну страховую компанию: сравниваем 15+ надёжных страховщиков в одном разговоре и оформляем полис там, где для вас лучшая цена.' },
      { q: 'Вы говорите по-русски?', a: 'Да! Мы говорим по-русски. Чат, звонок или SMS — на русском: (310) 299-5555. Русская версия сайта: <a href="/ru">covertoday.com/ru</a>.' },
      { q: 'В каких штатах вы лицензированы?', a: 'Калифорния (основной офис, лицензия #0K77310), а также Техас, Иллинойс, Аризона, Невада, Северная Каролина и Вашингтон.' },
      { q: 'Как быстро я получу подтверждение страховки?', a: 'В большинстве случаев — в тот же день: оформление полиса, SR-22 и DOT/MC filing день в день, сертификаты страхования (COI) — в течение нескольких часов.' },
      { q: 'Можно отправить вам документы?', a: 'Да — прикрепите фото прямо в окне чата (значок скрепки), отправьте на <a href="mailto:info@covertoday.com">info@covertoday.com</a> или SMS на (310) 299-5555. Регистрация, права и деклара­ционная страница текущего полиса ускоряют любую котировку.' },
      { q: 'Какие у вас часы работы?', a: 'Офис: пн–пт 9:00–18:30, сб 9:00–17:00 (тихоокеанское время). ИИ-ассистент в чате отвечает мгновенно 24/7, агент подключается в тот же рабочий день.' },
    ],
  },
  {
    id: 'auto',
    icon: '🚗',
    name: 'Авто и SR-22',
    faqs: [
      { q: 'Сколько стоит автостраховка?', a: 'Цена зависит от вашей истории вождения, машины, ZIP-кода и покрытия — единой цены нет. Мы сравниваем 15+ надёжных страховых компаний и применяем все скидки, на которые вы имеете право. Котировка бесплатна — быстрее всего просто спросить.' },
      { q: 'Какие скидки бывают на автостраховку?', a: 'Скидка за хорошего водителя (стаж 3+ года — опыт из любой страны считается — и не более 1 балла), за брак, семейная, за несколько машин, за несколько полисов (bundle) и другие. Агент применит всё автоматически.' },
      { q: 'У меня аварии, штрафы, DUI или нет прав. Вы застрахуете?', a: 'Да. Сложные случаи — наша специализация: аварии, баллы, DUI, приостановленные права, иностранные права — и даже полное отсутствие прав. Застраховать можно любую историю.' },
      { q: 'Что такое SR-22 и как быстро вы его оформите?', a: 'SR-22 — это сертификат финансовой ответственности, который подаётся в DMV (обычно после DUI, вождения без страховки или приостановки прав). Это не отдельный полис, а дополнение к автостраховке. Мы подаём SR-22 в тот же день.' },
      { q: 'Я недавно в США, у меня иностранные права. Какие варианты?', a: 'Мы страхуем водителей с иностранными и международными правами, и ваш зарубежный стаж может засчитаться для скидки за хорошего водителя. Многие наши клиенты начинали именно так.' },
      { q: 'Страхуете ли вы водителей Uber, Lyft, TCP?', a: 'Да — rideshare (Uber/Lyft), Uber Black и водителей и автопарки с TCP-разрешениями, включая коммерческие полисы, которые требуются для TCP.' },
      { q: 'Котировка — это обязательство? Повлияет на кредит?', a: 'Нет. Котировка — бесплатная оценка, решение за вами. Страховые котировки используют «мягкий» запрос, который не снижает кредитный рейтинг.' },
    ],
  },
  {
    id: 'trucking',
    icon: '🚛',
    name: 'Коммерческие траки',
    faqs: [
      { q: 'Какая страховка нужна для новой DOT authority?', a: 'Федеральный минимум: $750,000 ответственности для обычных грузов (GVWR более 10,001 фунтов) — на практике брокеры и грузоотправители требуют $1,000,000. Плюс cargo-страховка (обычно $100,000), physical damage на трак, а федеральные формы (BMC-91/91X) подаёт ваш брокер. Важно: подтверждение страховки должно поступить в FMCSA в течение 90 дней после заявки, иначе заявка аннулируется.' },
      { q: 'MC-номера ещё существуют в 2026 году?', a: 'В основном да, но регистрация изменилась. Новая система FMCSA Motus привязывает authority к номеру USDOT, выдаёт рандомизированные номера и по одному docket-номеру на каждую новую authority. Префиксы MC/MX/FF сохраняются; полная отмена docket-номеров пока только «рассматривается». Подробный разбор (на английском): <a href="/resources/mc-numbers-in-2026-fmcsa-motus-registration-and-insurance-explained">MC numbers & Motus в 2026</a>.' },
      { q: 'Сколько стоит страховка трака в Калифорнии?', a: 'Типичные рыночные диапазоны 2026 года: примерно $8,000–$16,000 в год для owner-operator с чистой историей, $12,000–$20,000+ для новой authority, больше — при нарушениях или страховых случаях. Leased-on owner-operator (только NTL + physical damage) обычно платит $3,000–$5,000.' },
      { q: 'Что нужно для котировки на трак?', a: 'Полезно (но не обязательно для старта): номер DOT или MC, тип трака и трейлера, радиус работы и тип груза. Работаем с owner-operators и автопарками: liability, physical damage, cargo, filings и COI в тот же день.' },
      { q: 'Можете выдать COI (сертификат страхования) сегодня?', a: 'Да — COI в тот же день для нас стандарт, обычно в течение пары часов: для брокеров, грузоотправителей и lease-договоров.' },
      { q: 'Страхуете ли box truck, hotshot, cargo van?', a: 'Да — box trucks, hotshots, cargo vans, dry vans, reefers, flatbeds, автовозы и локальную доставку. Под собственной authority или leased-on.' },
      { q: 'Продление страховки на трак резко подорожало. Сможете дешевле?', a: 'Часто — да. Цены у страховых компаний по тракам сильно различаются, и брокер с доступом к нескольким страховщикам пересматривает всю программу сразу (liability, cargo, physical damage). Пришлите декларационную страницу текущего полиса в чат или на info@covertoday.com — сравним.' },
    ],
  },
  {
    id: 'business',
    icon: '🏢',
    name: 'Страхование бизнеса',
    faqs: [
      { q: 'Что нужно малому бизнесу для котировки general liability?', a: 'Название бизнеса, сфера деятельности и число сотрудников — этого достаточно для старта. Страхуем подрядчиков, HVAC, ремонт техники, мувинговые компании, маникюрные и парикмахерские салоны и многие другие бизнесы.' },
      { q: 'Нужен COI для лицензии, арендодателя или контракта. Как быстро?', a: 'В тот же день, обычно в течение нескольких часов. Скажите, кого указать как certificate holder или additional insured — отправим напрямую.' },
      { q: 'Обязателен ли workers’ comp в Калифорнии?', a: 'Да — в Калифорнии workers’ compensation обязателен для любого бизнеса с сотрудниками, даже с одним на неполный день.' },
      { q: 'Можно объединить бизнес, авто и дом в пакет?', a: 'Да, и это обычно выгодно: скидки за несколько полисов действуют и для личных, и для коммерческих линий, а всеми полисами занимается один брокер — один номер телефона.' },
    ],
  },
  {
    id: 'claims',
    icon: '🛟',
    name: 'Аварии и изменения в полисе',
    faqs: [
      { q: 'Я попал в аварию. Что делать?', a: '1) Проверьте, нет ли пострадавших; при необходимости звоните 911. 2) Отойдите в безопасное место, обменяйтесь данными водителей и страховок, сфотографируйте машины и место ДТП. 3) Возьмите контакты свидетелей. 4) Подайте claim напрямую в отдел убытков вашей страховой компании — позвоните по номеру на страховой карточке и выберите опцию claims (обычно 24/7). 5) В Калифорнии также подайте в DMV форму SR-1 в течение 10 дней, если ущерб больше $1,000 или есть пострадавшие. Не знаете, какая у вас страховая? Подскажем бесплатно — даже если вы не наш клиент.' },
      { q: 'Как добавить машину или водителя, изменить адрес?', a: 'Напишите, что нужно изменить — в чате, по телефону/SMS (310) 299-5555 или на info@covertoday.com. Каждое изменение оформляет лицензированный агент; оно вступает в силу после подтверждения агентом или страховой компанией.' },
      { q: 'После страхового случая цена выросла. Что делать?', a: 'Дайте нам пересчитать. Один и тот же случай у разных страховщиков стоит по-разному — как независимые брокеры мы сравним 15+ компаний и переведём полис туда, где вашу историю оценят дешевле.' },
    ],
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'ru',
  mainEntity: cats.flatMap((c) => c.faqs).map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
  })),
};
---
<Base title="Вопросы и ответы о страховании — мгновенные ответы + ИИ-помощь | CoverToday" description="Ответы о страховании авто, SR-22, траков и бизнеса в Калифорнии — плюс ИИ-ассистент, который отвечает на ваш вопрос 24/7 по-русски и по-английски." lang="ru">
  <section class="hero"><div class="wrap">
    <h1>Вопросы? Отвечаем — мгновенно.</h1>
    <p class="sub">Посмотрите ответы ниже или задайте ИИ-ассистенту свой вопрос — 24/7, без форм, по-русски или по-английски. Лицензированные агенты — в одном шаге.</p>
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:18px">
      <button class="btn btn-call ask-ai" type="button">💬 Спросить ИИ сейчас</button>
      <a class="btn btn-ghost" href={`tel:${phone}`}>📞 (310) 299-5555</a>
    </div>
  </div></section>

  <section><div class="wrap" style="max-width:860px">
    <nav class="faq-nav" aria-label="Категории вопросов">
      {cats.map((c) => <a href={`#${c.id}`}>{c.icon} {c.name}</a>)}
    </nav>

    {cats.map((c) => (
      <div id={c.id} class="faq-cat">
        <h2 class="sec">{c.icon} {c.name}</h2>
        {c.faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <div class="faq-a">
              <p set:html={f.a}></p>
              <button class="ask-ai faq-ask" type="button">💬 Спросить ИИ об этом</button>
            </div>
          </details>
        ))}
      </div>
    ))}

    <div class="card" style="margin:40px 0;background:var(--blue-light);border:none;text-align:center;padding:30px">
      <h2 style="margin-top:0;color:var(--blue)">Не нашли свой вопрос?</h2>
      <p style="margin:8px 0 18px">Спросите ИИ-ассистента — он отвечает мгновенно, в любое время. Или свяжитесь с лицензированным агентом напрямую.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <button class="btn btn-call ask-ai" type="button">💬 Спросить ИИ</button>
        <a class="btn btn-ghost" href="/ru/quote">Бесплатная котировка →</a>
      </div>
    </div>
  </div></section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <script is:inline>
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.ask-ai');
      if (!btn) return;
      try {
        if (window.leadConnector && window.leadConnector.chatWidget) {
          window.leadConnector.chatWidget.openWidget();
          return;
        }
      } catch (err) {}
      window.location.href = 'tel:+13102995555';
    });
  </script>
</Base>

<style>
  .faq-nav{display:flex;gap:10px;flex-wrap:wrap;margin:6px 0 10px}
  .faq-nav a{background:var(--blue-light);color:var(--blue);font-weight:700;font-size:14px;padding:8px 14px;border-radius:999px;text-decoration:none}
  .faq-nav a:hover{filter:brightness(.96)}
  .faq-cat{margin-top:26px}
  .faq-item{border:1px solid #e3e8f0;border-radius:12px;margin:10px 0;background:#fff;overflow:hidden}
  .faq-item summary{cursor:pointer;padding:15px 18px;font-weight:700;font-size:16.5px;list-style:none;position:relative;padding-right:44px}
  .faq-item summary::-webkit-details-marker{display:none}
  .faq-item summary::after{content:'+';position:absolute;right:18px;top:50%;transform:translateY(-50%);font-size:22px;color:var(--blue);font-weight:800}
  .faq-item[open] summary::after{content:'\2212'}
  .faq-item[open] summary{border-bottom:1px solid #eef1f6}
  .faq-a{padding:14px 18px 16px}
  .faq-a p{margin:0 0 12px;font-size:16px;line-height:1.7;color:var(--ink)}
  .faq-ask{background:none;border:1.5px solid var(--blue);color:var(--blue);font-weight:700;font-size:13.5px;padding:7px 14px;border-radius:999px;cursor:pointer}
  .faq-ask:hover{background:var(--blue-light)}
</style>
