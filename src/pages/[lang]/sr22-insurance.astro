---
import Base from '../../layouts/Base.astro';
import { sr22 } from '../../i18n/content-standalone.js';
import { UI } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'ru' }, props: { c: sr22.ru, lang: 'ru' } },
    { params: { lang: 'es' }, props: { c: sr22.es, lang: 'es' } },
  ];
}
const { c, lang } = Astro.props;
const t = UI[lang];
const phone = '+13102995555';
---
<Base title={c.metaTitle} description={c.metaDesc}>
  <section class="hero"><div class="wrap">
    <h1>{c.h1}</h1>
    <p class="sub">{c.sub}</p>
    <div class="ctas">
      <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {t.callNow}</a>
      <a class="btn btn-text btn-lg" href={`sms:${phone}`}>💬 {t.textUs}</a>
    </div>
    <div class="reassure">{c.reassure.map((r) => (<span><span class="tick">✓</span> {r}</span>))}</div>
  </div></section>

  <section><div class="wrap" style="max-width:820px">
    <div class="eyebrow">{lang==='ru'?'Основное':'Lo básico'}</div>
    <h2 class="sec">{c.whatTitle}</h2>
    <p class="lead">{c.whatBody}</p>
  </div></section>

  <section class="soft"><div class="wrap">
    <div class="eyebrow">{t.simpleProcess}</div>
    <h2 class="sec">{t.howItWorks}</h2>
    <div class="grid grid-3">
      {c.steps.map((s, i) => (<div class="card"><div class="ic">{i + 1}</div><h3>{s.t}</h3><p>{s.d}</p></div>))}
    </div>
  </div></section>

  <section><div class="wrap" style="max-width:820px">
    <div class="eyebrow">{t.faq}</div>
    <h2 class="sec">{t.commonQuestions}</h2>
    <div style="margin-top:22px">
      {c.faqs.map((f) => (<details class="card" style="margin-bottom:12px"><summary style="font-weight:700;font-size:17px;cursor:pointer">{f.q}</summary><p style="margin-top:10px">{f.a}</p></details>))}
    </div>
  </div></section>
</Base>
