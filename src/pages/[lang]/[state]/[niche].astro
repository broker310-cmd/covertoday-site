---
import Base from '../../../layouts/Base.astro';
import { states } from '../../../data/states.js';
import { niches } from '../../../i18n/content-services.js';
import { UI } from '../../../i18n/ui.js';
import { cities, cityNichesI18n } from '../../../data/cities.js';

export function getStaticPaths() {
  const paths = [];
  for (const lang of ['ru', 'es']) {
    for (const st of states) {
      for (const n of niches[lang]) {
        paths.push({ params: { lang, state: st.slug, niche: n.slug }, props: { st, n, lang } });
      }
    }
    for (const c of cities) {
      for (const slug of c.niches) {
        const n = cityNichesI18n[lang][slug];
        paths.push({ params: { lang, state: c.slug, niche: slug }, props: { st: { name: c.name, abbr: c.abbr, slug: c.slug }, n, lang, community: c.community[lang], product: n.product, productLabel: n.label } });
      }
    }
  }
  return paths;
}
const { st, n, lang, community, product, productLabel } = Astro.props;
const t = UI[lang];
const phone = '+13102995555';
const title = `${n.label} — ${st.name} | CoverToday`;
const desc = n.sub(st.name).slice(0, 155);
---
<Base title={title} description={desc}>
  <section class="hero"><div class="wrap">
    <h1>{n.h1(st.name)}</h1>
    <p class="sub">{n.sub(st.name)}</p>
    <div class="ctas">
      <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {t.callNow}</a>
      <a class="btn btn-text btn-lg" href={`/${lang}/quote`}>{t.getFreeQuote}</a>
    </div>
    <div class="reassure">
      <span><span class="tick">✓</span> {st.name} ({st.abbr})</span>
      <span><span class="tick">✓</span> {lang==='ru'?'Оформление в тот же день':'Emisión el mismo día'}</span>
      <span><span class="tick">✓</span> {lang==='ru'?'Русскоговорящие агенты':'Hablamos español'}</span>
    </div>
  </div></section>

  <div class="trust"><div class="wrap">
    <span class="item">🏆 5.0 ★ Yelp</span>
    <span class="item">🤝 40+</span>
    <span class="item">⚡ {st.abbr}</span>
    <span class="item">🇷🇺 RU / EN / ES</span>
  </div></div>

  <section><div class="wrap" style="max-width:820px">
    <div class="eyebrow">{st.name}</div>
    <h2 class="sec">{n.label} — {st.name}</h2>
    <p class="lead">{n.body(st.name)}</p>
  </div></section>

  <section class="soft"><div class="wrap">
    <div class="eyebrow">{t.simpleProcess}</div>
    <h2 class="sec">{t.howItWorks}</h2>
    <div class="grid grid-3">
      {n.steps.map((s, i) => (<div class="card"><div class="ic">{i + 1}</div><h3>{s.t}</h3><p>{s.d}</p></div>))}
    </div>
  </div></section>

  {community && (
    <section><div class="wrap" style="max-width:820px">
      <div class="eyebrow">{lang==='ru'?'Русскоязычное сообщество':'Comunidad de habla rusa'}</div>
      <h2 class="sec">{lang==='ru'?`Обслуживаем русскоязычное сообщество в ${st.name}`:`Atendemos a la comunidad de habla rusa en ${st.name}`}</h2>
      <p class="lead">{community}</p>
      <div class="ctas" style="margin-top:22px">
        <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {t.callNow}</a>
        <a class="btn btn-text btn-lg" href={`/${lang}${product}`}>{lang==='ru'?`Подробнее: ${productLabel}`:`Ver detalles: ${productLabel}`}</a>
      </div>
    </div></section>
  )}
</Base>
