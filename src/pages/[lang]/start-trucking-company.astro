---
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }];
}

const faqs = [
  { q: 'Сколько стоит открыть транспортную компанию?', a: 'Сбор FMCSA за операционную авторизацию — $300 за каждую. Но главная статья расходов — страховка: новая authority обычно покупает $1M ответственности плюс $100K cargo, и взносы первого года — самые высокие. С чистыми инспекциями и без убытков продления заметно дешевеют. Получите страховые котировки до подачи документов.' },
  { q: 'Сколько времени занимает активация authority?', a: 'Закладывайте несколько недель: у самой авторизации есть период проверки, и она не активируется, пока страховая не подаст подтверждение покрытия (BMC-91/91X). Критично: подтверждение страховки должно быть подано в течение 90 дней с момента заявки, иначе заявка аннулируется и всё начинается заново. Подключайте страховку одновременно с заявкой.' },
  { q: 'Нужен ли MC-номер, если я вожу только внутри Калифорнии?', a: 'Нет — межштатная авторизация (MC docket) нужна для перевозок между штатами. Чисто внутриштатным калифорнийским перевозчикам вместо неё нужен CA Motor Carrier Permit (CA number) через DMV, с подтверждением страховки от вашей компании. USDOT-номер всё равно нужен, если машина тяжелее 10,001 фунтов GVWR. У перевозчиков домашних вещей — отдельный режим (permit BHGS/MTR).' },
  { q: 'Какую страховку требуют брокеры и грузоотправители?', a: 'Федеральный минимум для генеральных грузов свыше 10,001 фунтов — $750,000 ответственности, но на практике почти все брокеры и отправители требуют $1,000,000 ответственности и $100,000 motor truck cargo. У Amazon Relay и интермодальных перевозок (UIIA) — свои требования; мы делаем эти filings ежедневно.' },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};

const steps = [
  { n: '1', t: 'Оформите бизнес', d: 'Создайте компанию (чаще всего LLC), получите EIN в IRS, откройте бизнес-счёт. Сразу решите: своя authority или lease-on к действующему перевозчику — от этого зависит всё дальнейшее.' },
  { n: '2', t: 'Получите CDL (если водите сами)', d: 'CDL класса A через лицензированную школу; учитывайте требования ELDT (обучение начинающих водителей). Кто нанимает водителей — переходит к комплаенсу.' },
  { n: '3', t: 'USDOT-номер — через систему Motus FMCSA', d: 'Регистрация в портале Motus (обновлённая система регистрации FMCSA). Обязателен для коммерческого транспорта тяжелее 10,001 фунтов GVWR — даже если вы не выезжаете из Калифорнии.' },
  { n: '4', t: 'Операционная авторизация (MC docket) — для межштатных перевозок за плату', d: '$300 за авторизацию через Motus. Новые номера теперь выдаются рандомно, и каждая новая authority получает собственный docket. Authority НЕ активируется, пока не подана страховка.' },
  { n: '5', t: 'Страховка — начинайте с неё, а не в конце', d: 'Ловушка 90 дней: подтверждение страховки должно быть в деле в течение 90 дней после заявки, иначе заявка аннулируется. Ваша страховая подаёт BMC-91/91X по ответственности ($750K федеральный минимум для генгрузов; рыночный стандарт, который требуют брокеры, — $1M), плюс cargo $100K, physical damage при финансировании и NTL/bobtail при lease-on. Сначала котировки — потом документы.' },
  { n: '6', t: 'BOC-3 — процессуальные агенты', d: 'Назначьте process agents во всех штатах (одна «blanket» подача через агентство). Требуется до выдачи authority.' },
  { n: '7', t: 'UCR — Unified Carrier Registration', d: 'Ежегодная регистрация по размеру флота. Быстро и недорого — но половина новых перевозчиков вспоминает о ней только на дорожной проверке.' },
  { n: '8', t: 'Номера IRP + топливный счёт IFTA', d: 'Пропорциональные номера (IRP) и соглашение по топливному налогу (IFTA) через CA DMV/CDTFA для межштатной работы. Квартальные отчёты IFTA с первого дня — храните чеки на топливо.' },
  { n: '9', t: 'Внутри Калифорнии: Motor Carrier Permit', d: 'Перевозки за плату внутри штата требуют CA MCP (CA number) от DMV, с подтверждением страховки от вашей компании. Перевозчики домашних вещей — отдельно: permit BHGS/MTR с подачами TL 676 / TL 672 (не старый Cal-T).' },
  { n: '10', t: 'CARB Clean Truck Check', d: 'Дизельные грузовики тяжелее 14,000 фунтов, работающие в Калифорнии, должны быть зарегистрированы в программе CARB Clean Truck Check: ежегодный сбор плюс периодические проверки выбросов. Несоблюдение блокирует регистрацию в DMV.' },
  { n: '11', t: 'Программа drug & alcohol + Clearinghouse', d: 'Pre-employment тест до того, как любой водитель CDL (включая вас) сядет за руль, участие в консорциуме случайного тестирования, регистрация в FMCSA Clearinghouse и ежегодные проверки водителей.' },
  { n: '12', t: 'ELD, HOS и аудит New Entrant', d: 'Зарегистрированный ELD в машине, соблюдение hours-of-service, файлы квалификации водителей и записи обслуживания — аудит FMCSA New Entrant приходит в первые 12 месяцев. Чистые баллы CSA — это ещё и то, что снижает цену страховки при продлении.' },
];
---
<Base
  title="Как открыть транспортную компанию в Калифорнии — чек-лист 2026 | CoverToday"
  description="12 шагов: USDOT и MC через Motus, ловушка 90 дней со страховкой, BOC-3, UCR, IRP/IFTA, CA Motor Carrier Permit, CARB Clean Truck Check, Clearinghouse, ELD и аудит New Entrant. На русском."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <section class="hero"><div class="wrap">
    <h1>С нуля — до <span style="color:var(--accent)">собственной authority.</span></h1>
    <p class="sub">Чек-лист из 12 шагов для запуска транспортной компании в Калифорнии в 2026 году — в правильном порядке, включая ловушку 90 дней со страховкой, которая губит заявки.</p>
  </div></section>

  <section><div class="wrap guide">

    {steps.map(s => (
      <div class="gstep">
        <div class="gnum">{s.n}</div>
        <div>
          <h2>{s.t}</h2>
          <p>{s.d}</p>
        </div>
      </div>
    ))}

    <div class="gcard">
      <h2>После запуска: где на самом деле деньги</h2>
      <p>Грузы приходят от брокеров, с load boards и от прямых отправителей — и все они сначала проверяют вашу страховку и CSA-историю. У <strong>Amazon Relay</strong> и интермодальной/портовой работы (<strong>UIIA</strong>) есть свои страховые требования сверх стандартных $1M/$100K. Отработайте первый год чисто: <strong>продление страховки</strong> считается по вашим инспекциям и убыткам, и именно падение цены после первого года — момент, когда owner-operator начинает по-настоящему зарабатывать.</p>
      <p>Подробные разборы в блоге (англ.): <a href="/resources/mc-numbers-in-2026-fmcsa-motus-registration-and-insurance-explained">MC-номера и Motus в 2026</a> · <a href="/resources/how-much-does-commercial-truck-insurance-cost-in-california-2026">сколько стоит страховка грузовика</a>.</p>
    </div>

    <div class="gcard gcta">
      <h3>Страхование грузоперевозок — наша специализация.</h3>
      <p>Новые authority, owner-operators, флоты — котируем 15+ трансп. рынков, подаём BMC-91/91X и калифорнийские filings, выпускаем COI в тот же день. По-русски и по-английски.</p>
      <a class="btn btn-call btn-lg" href="/ru/quote">Получить расчёт</a>
      <p class="gphone">(310) 299-5555 · covertoday.com/ru/quote</p>
    </div>

    <h2 class="sec" style="font-size:24px">Частые вопросы</h2>
    {faqs.map(f => (
      <details class="gfaq"><summary>{f.q}</summary><p>{f.a}</p></details>
    ))}

    <p class="gdisc">Учебный чек-лист, не юридическая консультация — требования зависят от вашей операции; сверяйтесь с FMCSA, CA DMV и CARB. Независимый брокер — сравниваем несколько компаний; покрытие, право на него, цена и доступность зависят от компании и полиса и доступны не всем. Смотрите также: <a href="/ru/commercial-truck-insurance">страхование грузовиков</a> · <a href="/ru/cargo-van-sprinter-insurance">cargo van и Sprinter</a>.</p>

  </div></section>
</Base>

<style is:global>
  .guide{max-width:820px;padding-bottom:40px}
  .gstep{display:flex;gap:16px;background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:22px 24px;margin-bottom:12px}
  .gnum{flex:0 0 40px;height:40px;border-radius:12px;background:var(--blue);color:#fff;font-weight:800;font-size:18px;display:flex;align-items:center;justify-content:center}
  .gstep h2{font-size:18px;margin-bottom:4px}
  .gstep p{margin:0;color:var(--muted);font-size:15px;line-height:1.6}
  .gcard{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:26px 28px;margin:18px 0}
  .gcard h2{font-size:21px;margin-bottom:12px}
  .gcard p{margin:10px 0;color:var(--ink)}
  .gcard a{color:var(--blue);font-weight:600}
  .gcta{background:var(--blue-dark);color:#fff;text-align:center;padding:34px 28px}
  .gcta h3{color:#fff;font-size:23px}
  .gcta p{color:#fff;opacity:.88;max-width:560px;margin:10px auto 18px}
  .gphone{margin-top:14px !important;font-size:14px !important}
  .gfaq{background:#fff;border:1px solid var(--line);border-radius:14px;margin-bottom:8px;padding:0 18px}
  .gfaq summary{padding:14px 0;cursor:pointer;font-weight:700}
  .gfaq p{padding:0 0 16px;color:var(--muted)}
  .gdisc{color:var(--muted);font-size:13px;margin:24px 0 10px}
  .gdisc a{color:var(--blue)}
</style>
