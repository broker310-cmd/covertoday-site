---
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }];
}

const faqs = [
  { q: 'Обязан ли я сообщать о ДТП в DMV Калифорнии?', a: 'Да — если кто-то пострадал (даже легко), кто-то погиб или ущерб имуществу превышает $1,000, вы обязаны подать форму SR-1 в DMV в течение 10 дней. Это требуется в дополнение к полицейскому отчёту и страховой заявке, а игнорирование может стоить вам прав.' },
  { q: 'Когда после аварии нужно вызывать полицию?', a: 'Если кто-то пострадал — звоните 911 сразу. При любых травмах или гибели о ДТП нужно сообщить в полицию или CHP в течение 24 часов. На мелкие аварии без пострадавших полиция часто не выезжает — фиксируйте всё сами и подайте SR-1, если ущерб больше $1,000.' },
  { q: 'Что делать, если у второго водителя нет страховки?', a: 'Именно для этого существует покрытие uninsured motorist (UM/UIM) — оно работает на ваши травмы, а с UM property damage и на машину. В Калифорнии доля незастрахованных водителей велика, поэтому мы рекомендуем UM каждому клиенту. Не уверены, что оно у вас есть — проверьте полис сегодня, а не после аварии.' },
  { q: 'Подорожает ли моя страховка после ДТП?', a: 'Зависит от вины. Авария по вашей вине обычно повышает тариф и может лишить вас калифорнийской скидки Good Driver в 20%. Если вы не виноваты, правила Калифорнии, как правило, запрещают страховщику повышать вам цену за это. В любом случае независимый брокер может заново сравнить рынок, если тариф вырос.' },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};
---
<Base
  title="Что делать при ДТП в Калифорнии — чек-лист по шагам | CoverToday"
  description="Пошаговый план после аварии в Калифорнии: что делать на месте, что фотографировать, правило SR-1 (10 дней), страховая заявка и сроки. На русском языке."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <section class="hero"><div class="wrap">
    <h1>Попали в аварию? <span style="color:var(--accent)">Спокойно.</span></h1>
    <p class="sub">Вот что делать — шаг за шагом: на месте, в первые 10 дней и после. Сохраните эту страницу до того, как она понадобится.</p>
  </div></section>

  <section><div class="wrap guide">

    <div class="gcard">
      <h2>🚨 На месте — первые 10 минут</h2>
      <ol>
        <li><strong>Проверьте, есть ли пострадавшие.</strong> Если кто-то ранен — сначала 911. Всё остальное вторично.</li>
        <li><strong>Уберите машины с проезжей части.</strong> Если машины на ходу и серьёзно пострадавших нет, съедьте с полосы и включите аварийку — стоящие в потоке машины вызывают вторые аварии.</li>
        <li><strong>Не признавайте вину.</strong> Ни второму водителю, ни свидетелям. Даже вежливое «извините» потом цитируют. Только факты, спокойно.</li>
        <li><strong>Полиция обязательна при травмах</strong> — и помните: о ДТП с травмами или гибелью нужно сообщить в полицию или CHP в течение 24 часов.</li>
      </ol>
    </div>

    <div class="gcard">
      <h2>📸 Обмен данными и фиксация — пока никто не уехал</h2>
      <p>Возьмите у второго водителя:</p>
      <ul>
        <li>Имя, телефон и адрес</li>
        <li>Номер водительского удостоверения</li>
        <li>Номерной знак + марку/модель/год машины</li>
        <li>Страховую компанию <strong>и номер полиса</strong> (сфотографируйте страховую карточку)</li>
      </ul>
      <p>Сфотографируйте:</p>
      <ul>
        <li>Обе машины со всех четырёх углов, затем повреждения крупно</li>
        <li>Оба номерных знака и страховую карточку второго водителя</li>
        <li>Всю сцену: положение машин, следы торможения, знаки и светофоры, состояние дороги</li>
        <li>Видимые травмы</li>
      </ul>
      <p>Запишите <strong>имена и телефоны свидетелей</strong> и номер полицейского отчёта, если полиция приезжала. Две минуты фотографий могут решить спор о вине через несколько месяцев.</p>
    </div>

    <div class="gcard">
      <h2>📋 Отчёт, о котором все забывают: SR-1 за 10 дней</h2>
      <p>Закон Калифорнии обязывает вас (или вашего страхового агента/брокера) подать форму <strong>SR-1</strong> в DMV <strong>в течение 10 дней</strong>, если в аварии есть <strong>любая травма, гибель или ущерб больше $1,000</strong> — а это сегодня почти любая заметная вмятина.</p>
      <ul>
        <li>SR-1 обязателен, <strong>даже если полиция составила отчёт</strong> и даже если вы подали страховую заявку — это отдельная обязанность.</li>
        <li>Обязателен, <strong>даже если вы не виноваты</strong>.</li>
        <li>Неподача может привести к <strong>приостановке прав</strong>.</li>
      </ul>
      <p>Подать можно онлайн или почтой через <a href="https://www.dmv.ca.gov/portal/dmv-virtual-office/accident-reporting/" target="_blank" rel="noopener">страницу DMV об отчётах о ДТП (англ.)</a>. Нашим клиентам мы помогаем с SR-1 — один звонок.</p>
    </div>

    <div class="gcard">
      <h2>📞 Страховая заявка</h2>
      <ul>
        <li><strong>Сообщите своей страховой сразу</strong> — этого требует полис, а промедление даёт фору версии второй стороны.</li>
        <li>Калифорния — штат <strong>«виновника»</strong>: платит страховая виновного. Вина может делиться в процентах.</li>
        <li>Если второй водитель не застрахован или застрахован недостаточно — работает ваше покрытие <strong>UM/UIM</strong>, если вы его купили.</li>
        <li>Не спешите принимать быстрый расчёт, пока не ясен полный объём травм и ремонта.</li>
      </ul>
      <p>Сроки (общая информация, не юридическая консультация): иск о <strong>травмах</strong> в Калифорнии обычно подаётся в течение <strong>2 лет</strong>, об <strong>ущербе имуществу</strong> — в течение <strong>3 лет</strong>. При серьёзных травмах поговорите с адвокатом как можно раньше.</p>
    </div>

    <div class="gcard gcta">
      <h3>Проверять покрытие лучше до аварии, а не после.</h3>
      <p>Есть ли у вас uninsured motorist? Аренда машины на время ремонта? Правильные лимиты (минимумы Калифорнии теперь 30/60/15)? Проверим ваш полис бесплатно — по-русски или по-английски.</p>
      <a class="btn btn-call btn-lg" href="/ru/quote">Бесплатная проверка полиса</a>
      <p class="gphone">(310) 299-5555 · covertoday.com/ru/quote</p>
    </div>

    <h2 class="sec" style="font-size:24px">Частые вопросы</h2>
    {faqs.map(f => (
      <details class="gfaq"><summary>{f.q}</summary><p>{f.a}</p></details>
    ))}

    <p class="gdisc">Этот чек-лист — учебный материал, не юридическая консультация. Независимый брокер — сравниваем несколько компаний; покрытие, право на него, цена и доступность зависят от компании и полиса и доступны не всем. Смотрите также: <a href="/ru/dmv-practice-test">бесплатный тест DMV</a> · <a href="/ru/insurance-savings">как платить меньше за страховку</a>.</p>

  </div></section>
</Base>

<style is:global>
  .guide{max-width:820px;padding-bottom:40px}
  .gcard{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:26px 28px;margin-bottom:18px}
  .gcard h2{font-size:21px;margin-bottom:12px}
  .gcard p{margin:10px 0;color:var(--ink)}
  .gcard ul,.gcard ol{margin:10px 0 10px 22px}
  .gcard li{margin:7px 0;line-height:1.6}
  .gcard a{color:var(--blue);font-weight:600}
  .gcta{background:var(--blue-dark);color:#fff;text-align:center;padding:34px 28px}
  .gcta h3{color:#fff;font-size:23px}
  .gcta p{color:#fff;opacity:.88;max-width:560px;margin:10px auto 18px}
  .gphone{margin-top:14px !important;font-size:14px !important}
  .gfaq{background:#fff;border:1px solid var(--line);border-radius:14px;margin-bottom:8px;padding:0 18px}
  .gfaq summary{padding:14px 0;cursor:pointer;font-weight:700}
  .gfaq p{padding:0 0 16px;color:var(--muted)}
  .gdisc{color:var(--muted);font-size:13px;margin:24px 0 10px}
  .gdisc a{color:var(--blue)}
</style>
