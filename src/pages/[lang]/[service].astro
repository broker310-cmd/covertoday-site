---
import Base from '../../layouts/Base.astro';
import { services } from '../../i18n/content-services.js';
import { UI } from '../../i18n/ui.js';
import { relatedMap, LABELS, relatedTitle } from '../../data/related.js';

export function getStaticPaths() {
  const paths = [];
  for (const lang of ['ru']) {
    for (const s of services[lang]) {
      paths.push({ params: { lang, service: s.slug }, props: { s, lang } });
    }
  }
  return paths;
}
const { s, lang } = Astro.props;
const t = UI[lang];
const phone = '+13102995555';
const L = {
  ru: { askAi: 'Спросить ИИ — мгновенный ответ 24/7', allFaq: 'Все вопросы и ответы', guides: 'Гайды', learnMore: 'Узнать больше', coverage: 'Покрытие', covers: 'Что покрывает', pricing: 'Цены', cost: 'Сколько стоит', req: 'Требования', who: 'Кому нужно', quoteNote: 'Это ориентировочные рыночные диапазоны — точная цена зависит от вашего профиля. Звоните', free: 'для бесплатного расчёта.' },
  es: { coverage: 'Cobertura', covers: 'Qué cubre', pricing: 'Precios', cost: 'Cuánto cuesta', req: 'Requisitos', who: 'Quién lo necesita', quoteNote: 'Son rangos de mercado generales — su tarifa exacta depende de su perfil. Llame al', free: 'para una cotización gratis.' },
}[lang];
const rel = relatedMap[s.slug] || [];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": (s.faqs || []).map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---
<Base title={s.metaTitle} description={s.metaDesc}>
  <section class="hero"><div class="wrap">
    <h1>{s.h1}</h1>
    <p class="sub">{s.sub}</p>
    <div class="ctas">
      <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {t.callNow}</a>
      <a class="btn btn-text btn-lg" href={`/${lang}/quote`}>{t.getFreeQuote}</a>
    </div>
    <div class="reassure">{s.reassure.map((r) => (<span><span class="tick">✓</span> {r}</span>))}</div>
  </div></section>

  <div class="trust"><div class="wrap">
    <span class="item">🏆 5.0 ★ Yelp</span>
    <span class="item">🤝 40+</span>
    <span class="item">⚡ {lang==='ru'?'В тот же день':'El mismo día'}</span>
    <span class="item">🇷🇺 RU / EN</span>
  </div></div>

  <section><div class="wrap" style="max-width:820px">
    <div class="eyebrow">{t.whyCoverToday}</div>
    <h2 class="sec">{s.whatTitle}</h2>
    <p class="lead">{s.whatBody}</p>
  </div></section>

  {s.covers && (
    <section class="soft"><div class="wrap">
      <div class="eyebrow">{L.coverage}</div>
      <h2 class="sec">{L.covers}</h2>
      <div class="grid grid-3">
        {s.covers.map((c) => (<div class="card"><h3>{c.t}</h3><p>{c.d}</p></div>))}
      </div>
    </div></section>
  )}

  {s.cost && (
    <section><div class="wrap" style="max-width:820px">
      <div class="eyebrow">{L.pricing}</div>
      <h2 class="sec">{L.cost}</h2>
      <p class="lead">{s.cost}</p>
      <p style="margin-top:10px;color:var(--muted);font-size:14px">{L.quoteNote} <a href={`tel:${phone}`}>(310) 299-5555</a> {L.free}</p>
    </div></section>
  )}

  {s.whoNeeds && (
    <section class="soft"><div class="wrap" style="max-width:820px">
      <div class="eyebrow">{L.req}</div>
      <h2 class="sec">{L.who}</h2>
      <p class="lead">{s.whoNeeds}</p>
    </div></section>
  )}

  <section><div class="wrap" style="max-width:820px">
    <div class="eyebrow">{t.simpleProcess}</div>
    <h2 class="sec">{t.howItWorks}</h2>
    <div class="grid grid-3">
      {s.steps.map((st, i) => (<div class="card"><div class="ic">{i + 1}</div><h3>{st.t}</h3><p>{st.d}</p></div>))}
    </div>
  </div></section>

  <section class="soft"><div class="wrap" style="max-width:820px">
    <div class="eyebrow">{t.faq}</div>
    <h2 class="sec">{t.commonQuestions}</h2>
    <div style="margin-top:22px">
      {s.faqs.map((f) => (<details class="card" style="margin-bottom:12px"><summary style="font-weight:700;font-size:17px;cursor:pointer">{f.q}</summary><p style="margin-top:10px">{f.a}</p></details>))}
    </div>
    <p style="margin-top:18px;display:flex;gap:10px;flex-wrap:wrap">
      <button class="btn btn-ghost ask-ai" type="button">💬 {L.askAi}</button>
      <a class="btn btn-ghost" href={`/${lang}/faq`}>{L.allFaq}</a>
    </p>
  </div></section>

  {s.guides && s.guides.length > 0 && (
    <section><div class="wrap" style="max-width:820px">
      <div class="eyebrow">{L.guides}</div>
      <h2 class="sec">{L.learnMore}</h2>
      <div style="display:flex;flex-direction:column;gap:10px;margin-top:14px">
        {s.guides.map((g) => (<a class="card" href={g.href} style="text-decoration:none"><strong>{g.t}</strong> <span style="color:var(--blue)">→</span></a>))}
      </div>
    </div></section>
  )}

  {rel.length > 0 && (
    <section class="soft"><div class="wrap" style="max-width:820px">
      <div class="eyebrow">{relatedTitle[lang]}</div>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:6px">
        {rel.map((r) => (<a class="btn btn-ghost" href={`/${lang}/${r}`}>{LABELS[lang][r]}</a>))}
      </div>
    </div></section>
  )}

  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <script is:inline>
    // «Спросить ИИ» → открыть чат-виджет; запасной вариант — звонок.
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.ask-ai');
      if (!btn) return;
      try {
        if (window.leadConnector && window.leadConnector.chatWidget) {
          window.leadConnector.chatWidget.openWidget();
          return;
        }
      } catch (err) {}
      window.location.href = 'tel:+13102995555';
    });
  </script>
</Base>
