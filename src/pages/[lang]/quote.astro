---
import Base from '../../layouts/Base.astro';
import { quote } from '../../i18n/content-standalone.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'ru' }, props: { c: quote.ru, lang: 'ru' } },
  ];
}
const { c, lang } = Astro.props;
const WEBHOOK_URL = 'https://services.leadconnectorhq.com/hooks/eYZdYbKt9k4UeIF4JLJJ/webhook-trigger/32bb8191-de93-4bc7-9ff5-6a95fb6599f4';
const thankYou = `/${lang}/thank-you`;
---
<Base title={c.metaTitle} description={c.metaDesc}>
  <section class="hero"><div class="wrap">
    <h1>{c.h1}</h1>
    <p class="sub">{c.sub}</p>
  </div></section>

  <section><div class="wrap" style="max-width:640px">
    <form class="card" style="padding:30px" action="https://formsubmit.co/info@covertoday.com" method="POST">
      <h2 class="sec" style="font-size:24px">{c.formTitle}</h2>
      <input type="hidden" name="_subject" value="New quote request (covertoday.com)" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_next" value={`https://covertoday.com${thankYou}`} />
      <input type="text" name="_honey" style="display:none" />
      <label>{c.name}</label><input name="name" required />
      <label>{c.phone}</label><input name="phone" type="tel" required />
      <label>Email <span style="font-weight:400">(необязательно)</span></label><input name="email" type="email" />
      <label>{c.zip}</label><input name="zip" required />
      <label>{c.need}</label>
      <select name="line">{c.options.map((o) => (<option>{o}</option>))}</select>
      <label style="display:flex;gap:10px;align-items:flex-start;margin-top:16px;font-weight:400;font-size:13px;line-height:1.5;color:var(--muted);cursor:pointer">
        <input type="checkbox" name="sms_consent" value="yes" style="width:auto;margin-top:3px;flex-shrink:0" />
        <span>{c.smsConsent}</span>
      </label>
      <button class="btn btn-call" type="submit" style="width:100%;justify-content:center;margin-top:18px">{c.button}</button>
      <p style="text-align:center;color:var(--muted);font-size:13px;margin-top:10px">{c.or}</p>
      <p style="text-align:center;color:var(--muted);font-size:12px;margin-top:8px;line-height:1.5" set:html={c.legal}></p>
    </form>
  </div></section>

  <style>
    form label{display:block;font-size:13px;font-weight:700;color:var(--muted);margin:14px 0 5px}
    form input,form select{width:100%;padding:12px 14px;border:1.5px solid var(--line);border-radius:10px;font-size:15px;font-family:inherit}
    form input:focus,form select:focus{outline:none;border-color:var(--blue)}
  </style>
  <script is:inline define:vars={{ webhook: WEBHOOK_URL, thankYou }}>
    const form = document.querySelector('form');
    let sending = false;
    form.addEventListener('submit', async (e) => {
      if (sending) return; // allow native fallback resubmit
      const p = form.querySelector('input[name="phone"]');
      const d = p.value.replace(/\D/g, '');
      if (d.length === 10) p.value = '+1' + d;
      else if (d.length === 11 && d.startsWith('1')) p.value = '+' + d;
      if (form.querySelector('input[name="_honey"]').value) return; // bot
      if (!webhook || webhook === 'WEBHOOK_URL_TBD') return; // native FormSubmit path
      e.preventDefault();
      sending = true;
      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      const payload = {
        full_name: form.name.value.trim(),
        phone: p.value,
        email: form.email.value.trim(),
        zip: form.zip.value.trim(),
        insurance_type: form.line.value,
        sms_consent: form.sms_consent.checked ? 'yes' : 'no',
        source: 'RU quote form (covertoday.com/ru/quote)',
        page: location.href,
        consent_language: form.sms_consent.checked ? form.querySelector('input[name="sms_consent"]').nextElementSibling.textContent : '',
        submitted_at: new Date().toISOString()
      };
      try {
        const r = await fetch(webhook, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        if (!r.ok) throw new Error('webhook ' + r.status);
        location.href = thankYou;
      } catch (err) {
        sending = false; btn.disabled = false;
        form.submit(); // fallback: FormSubmit email path
      }
    });
  </script>
</Base>
