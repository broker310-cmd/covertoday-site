---
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }];
}

const faqs = [
  { q: 'Traffic school убирает штраф совсем?', a: 'Не совсем — вы всё равно платите штраф, судебный сбор и стоимость курса. Но приговор остаётся конфиденциальным: пункт скрыт из вашей истории, и страховые его не видят. Для большинства водителей это защищает скидку Good Driver в 20%, которая обычно стоит намного дороже курса.' },
  { q: 'Сколько на самом деле стоит один пункт?', a: 'Штраф — это меньшая часть. Видимый пункт может лишить вас 20% скидки Good Driver на годы и поднять базовый тариф. В зависимости от взноса один штраф незаметно обходится в тысячи долларов за три года — поэтому оспорить или скрыть его часто выгодно.' },
  { q: 'Что будет, если офицер не ответит на моё письменное заявление?', a: 'В процедуре Trial by Written Declaration офицер обязан ответить письменно. Если ответа нет, дело обычно прекращают — одна из причин, почему письменные разбирательства выигрывают чаще, чем принято думать. Если проиграли — как правило, можно запросить новое очное разбирательство (trial de novo) в течение 20 дней.' },
  { q: 'У меня коммерческие права (CDL). Можно ли traffic school?', a: 'Для коммерческих прав traffic school, как правило, не скрывает нарушения так, как для обычных, а пункты угрожают вашему заработку. Водителям CDL стоит относиться к любому штрафу серьёзно: оспаривать или консультироваться с адвокатом. Спросите нас, как нарушение отразится на коммерческой страховке, прежде чем решать.' },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};
---
<Base
  title="Получили штраф в Калифорнии? Ваши 5 вариантов | CoverToday"
  description="Оплатить, скрыть через traffic school, исправить и закрыть, оспорить письменно (Trial by Written Declaration) или идти в суд — как работает каждый вариант и что он значит для страховки. На русском."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <section class="hero"><div class="wrap">
    <h1>Штраф — это ещё <span style="color:var(--accent)">не приговор.</span></h1>
    <p class="sub">В Калифорнии у вас пять вариантов — и самый дешёвый обычно не «просто заплатить». Разбираем каждый и его последствия для страховки.</p>
  </div></section>

  <section><div class="wrap guide">

    <div class="gcard">
      <h2>Сначала: прочитайте courtesy notice</h2>
      <p>Суд каждого округа работает немного по-своему. В уведомлении, которое суд присылает почтой, указаны срок, сумма (bail), право на traffic school и порядок оспаривания. Никогда не пропускайте срок — из простого нарушения это превращается в блокировку прав и дополнительный сбор.</p>
    </div>

    <div class="gcard">
      <h2>Вариант 1 — просто заплатить</h2>
      <p>Быстрее всего — и дороже всего в долгую. Оплата = приговор: пункт попадает в историю (большинство «однопунктовых» нарушений учитываются около 3 лет), страховая его видит, и вы можете потерять <strong>скидку Good Driver 20%</strong>. Сам штраф — часто наименьшая из потерь.</p>
    </div>

    <div class="gcard">
      <h2>Вариант 2 — traffic school (скрыть пункт)</h2>
      <p>Для большинства мелких нарушений, если вы не использовали traffic school за последние <strong>18 месяцев</strong>, можно заплатить штраф и сборы, пройти одобренный курс (онлайн подходит) — и приговор останется <strong>конфиденциальным</strong>: страховые пункт не увидят.</p>
      <ul>
        <li>Обычно лучший вариант, когда доступен: несколько часов и ~$50–100 сборов против годов повышенных взносов.</li>
        <li>Недоступен для серьёзных нарушений и, как правило, не скрывает пункты для <strong>CDL</strong>.</li>
      </ul>
    </div>

    <div class="gcard">
      <h2>Вариант 3 — «fix-it» штрафы: исправил и закрыл</h2>
      <p>Исправимые нарушения — неработающая фара, просроченная регистрация, отсутствие подтверждения страховки — закрываются, когда вы устраняете проблему, получаете подпись о проверке (полиция, DMV или суд — зависит от нарушения) и платите небольшой сбор за закрытие (обычно $25). Не платите их как обычные штрафы.</p>
    </div>

    <div class="gcard">
      <h2>Вариант 4 — Trial by Written Declaration (оспорить письменно)</h2>
      <p>Калифорния позволяет оспорить нарушение полностью письменно — без похода в суд:</p>
      <ol>
        <li>Запросите процедуру до срока оплаты и <strong>внесите bail</strong> (сумму штрафа — суд её держит).</li>
        <li>Подайте форму <strong>TR-205</strong> с письменным объяснением и доказательствами (фото, схемы).</li>
        <li>Офицер обязан ответить <strong>письменно</strong>. Если не ответил — дела обычно прекращают.</li>
        <li>Выиграли — полный возврат денег. Проиграли — как правило, можно запросить <strong>trial de novo</strong> (новое очное разбирательство) в течение <strong>20 дней</strong>. (Осторожно: в судах с онлайн-системой MyCitations опция trial de novo может быть недоступна.)</li>
      </ol>
      <p>Формы и подробности: <a href="https://selfhelp.courts.ca.gov/traffic/trial-declaration" target="_blank" rel="noopener">официальный гид судов Калифорнии (англ.)</a>.</p>
    </div>

    <div class="gcard">
      <h2>Вариант 5 — очный суд или адвокат</h2>
      <p>В серьёзных случаях — мисдиминоры, очень высокая скорость, штраф при ДТП или всё, что касается <strong>коммерческих прав</strong>, — очный суд или дорожный адвокат стоят своих денег. Если офицер не является в суд, дело нередко прекращают.</p>
    </div>

    <div class="gcard gcta">
      <h3>Пункт уже в истории — или боитесь за тариф?</h3>
      <p>Расскажите, что случилось. Проверим, сохранится ли ваша скидка Good Driver, а если компания подняла цену — заново сравним 15+ компаний и найдём ту, что оценит вашу историю мягче. По-русски и по-английски.</p>
      <a class="btn btn-call btn-lg" href="/ru/quote">Проверить мою цену</a>
      <p class="gphone">(310) 299-5555 · covertoday.com/ru/quote</p>
    </div>

    <h2 class="sec" style="font-size:24px">Частые вопросы</h2>
    {faqs.map(f => (
      <details class="gfaq"><summary>{f.q}</summary><p>{f.a}</p></details>
    ))}

    <p class="gdisc">Страница носит учебный характер и не является юридической консультацией — процедуры зависят от округа и дела. Независимый брокер — сравниваем несколько компаний; покрытие, право на него, цена и доступность зависят от компании и полиса и доступны не всем. Смотрите также: <a href="/ru/insurance-savings">как платить меньше за страховку</a> · <a href="/ru/sr22-insurance">страховка SR-22</a> · <a href="/ru/dmv-practice-test">бесплатный тест DMV</a>.</p>

  </div></section>
</Base>

<style is:global>
  .guide{max-width:820px;padding-bottom:40px}
  .gcard{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:26px 28px;margin-bottom:18px}
  .gcard h2{font-size:21px;margin-bottom:12px}
  .gcard p{margin:10px 0;color:var(--ink)}
  .gcard ul,.gcard ol{margin:10px 0 10px 22px}
  .gcard li{margin:7px 0;line-height:1.6}
  .gcard a{color:var(--blue);font-weight:600}
  .gcta{background:var(--blue-dark);color:#fff;text-align:center;padding:34px 28px}
  .gcta h3{color:#fff;font-size:23px}
  .gcta p{color:#fff;opacity:.88;max-width:560px;margin:10px auto 18px}
  .gphone{margin-top:14px !important;font-size:14px !important}
  .gfaq{background:#fff;border:1px solid var(--line);border-radius:14px;margin-bottom:8px;padding:0 18px}
  .gfaq summary{padding:14px 0;cursor:pointer;font-weight:700}
  .gfaq p{padding:0 0 16px;color:var(--muted)}
  .gdisc{color:var(--muted);font-size:13px;margin:24px 0 10px}
  .gdisc a{color:var(--blue)}
</style>
