---
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }];
}

const faqs = [
  { q: 'Минимальное покрытие — самый дешёвый способ застраховаться?', a: 'У него самый низкий взнос, но после аварии это часто самый дорогой выбор. Минимумы Калифорнии (30/60/15 с 2025 года) в реальном ДТП заканчиваются быстро, а всё сверх них платите вы. Умнее снижать цену скидками, франшизой и сравнением компаний, а не урезанием защиты.' },
  { q: 'Влияет ли кредитная история на цену автостраховки в Калифорнии?', a: 'Нет. Калифорния — один из немногих штатов, где запрещено использовать кредитную историю в тарифах на автострахование. Значение имеют водительский стаж, история нарушений, годовой пробег и машина — поэтому чистая история вождения напрямую защищает ваш тариф.' },
  { q: 'Сколько экономит скидка Good Driver?', a: 'По закону (Proposition 103) хорошие водители получают минимум 20% скидки. Обычно нужно: стаж от 3 лет и не больше 1 пункта в истории. Одна авария по вашей вине или «видимый» штраф могут лишить этой скидки на годы — часто это дороже самого штрафа.' },
  { q: 'Что такое программа CLCA?', a: 'Государственная программа Калифорнии по доступному автострахованию (mylowcostauto.com) — полисы ответственности для водителей с невысоким доходом и машиной дешевле $25,000. Иногда это правильный мост, а иногда обычная компания оказывается выгоднее — мы честно скажем, что лучше в вашем случае.' },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};

const groups = [
  { icon: '⭐', t: 'Используйте права, которые даёт Калифорния', items: [
    { t: 'Скидка Good Driver 20% — это закон', d: 'Proposition 103 гарантирует хорошим водителям минимум 20% скидки: как правило, стаж от 3 лет и не более 1 пункта. Если вы подходите, а скидки не видите — спрашивайте. Это главный рычаг экономии в Калифорнии.' },
    { t: 'Кредитный рейтинг не может работать против вас', d: 'В Калифорнии запрещено ценообразование по кредитной истории. Решает история вождения — поэтому, когда штраф можно закрыть traffic school, это обычно окупается: пункт остаётся скрытым от страховых.' },
    { t: 'CLCA — государственная программа', d: 'Водителям с невысоким доходом и машиной дешевле $25,000 доступны государственные полисы ответственности (mylowcostauto.com). Стоит проверить, если бюджет — главное ограничение.' },
  ]},
  { icon: '🛒', t: 'Покупайте как профессионал', items: [
    { t: 'Сравнивайте компании — по-настоящему', d: 'Одному и тому же водителю разные компании называют совершенно разные цены. Независимый брокер сравнивает 15+ компаний за один заход — в этом и смысл брокера.' },
    { t: 'Пересматривайте цену при продлении и переменах в жизни', d: 'Переехали? Сменили работу или маршрут? Добавился год чистого стажа? Компании по-разному оценивают разные профили — лучшая цена прошлого года часто уже не лучшая.' },
    { t: 'Никогда не допускайте разрыва в страховке', d: 'Даже несколько дней без полиса помечают вас как риск и поднимают цены по всему рынку. Если туго с деньгами — уменьшайте покрытие, но не отменяйте полис.' },
  ]},
  { icon: '⚙️', t: 'Настройте сам полис', items: [
    { t: 'Поднимите франшизу (deductible)', d: 'Переход с $500 на $1,000 заметно снижает часть взноса за collision/comprehensive. Просто держите разницу отложенной.' },
    { t: 'Уберите collision со старой машины', d: 'Если машина стоит немногим больше франшизы плюс года взносов за collision, полное покрытие может уже не иметь смысла. Посчитаем это вместе.' },
    { t: 'Объединяйте полисы и берите скидки за оплату', d: 'Авто + жильё/аренда, оплата сразу за период, автосписание, электронные документы — по отдельности скидки небольшие, но складываются.' },
  ]},
  { icon: '🚗', t: 'Полис под вашу жизнь', items: [
    { t: 'Сообщайте о меньшем пробеге', d: 'Ездите меньше — удалёнка, пенсия, переезд ближе к работе? Годовой пробег — важный фактор тарифа в Калифорнии. Скажите страховой.' },
    { t: 'Студенческие скидки', d: 'Скидка за хорошую учёбу (обычно средний балл B) и скидка за студента, уехавшего учиться без машины, — о них забывают чаще всего.' },
    { t: 'Курс для водителей 55+', d: 'Одобренный курс повышения мастерства для зрелых водителей даёт скидку у многих компаний.' },
  ]},
];
---
<Base
  title="Как платить меньше за автостраховку в Калифорнии — 12 способов | CoverToday"
  description="Реальные способы снизить цену автостраховки в Калифорнии: скидка Good Driver 20%, запрет кредитного рейтинга, программа CLCA, франшизы, пробег и сравнение компаний. На русском."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <section class="hero"><div class="wrap">
    <h1>Хватит <span style="color:var(--accent)">переплачивать</span> за страховку.</h1>
    <p class="sub">Двенадцать способов, которыми калифорнийцы реально снижают взнос, — включая три права, о которых большинство водителей не знает. Без трюков и без урезания защиты.</p>
  </div></section>

  <section><div class="wrap guide">

    {groups.map(g => (
      <div class="gcard">
        <h2>{g.icon} {g.t}</h2>
        {g.items.map(it => (
          <div class="gitem">
            <h3>{it.t}</h3>
            <p>{it.d}</p>
          </div>
        ))}
      </div>
    ))}

    <div class="gcard">
      <h2>⚠️ Одно предупреждение</h2>
      <p>Не путайте дешёвый взнос с выгодой. Минимальные лимиты Калифорнии (30/60/15) — это юридический пол, а не рекомендация: в серьёзной аварии они заканчиваются быстро, а остальное платится из ваших активов и зарплаты. Цель — <strong>правильное покрытие по лучшей доступной цене</strong>, а не минимальное покрытие.</p>
    </div>

    <div class="gcard gcta">
      <h3>Хотите, чтобы мы прошли все 12 пунктов за вас?</h3>
      <p>Пришлите текущий полис — проверим каждую упущенную скидку, сравним 15+ компаний и честно скажем, если ваша цена уже хорошая. Бесплатно, по-русски или по-английски.</p>
      <a class="btn btn-call btn-lg" href="/ru/quote">Сравнить мою цену</a>
      <p class="gphone">(310) 299-5555 · covertoday.com/ru/quote</p>
    </div>

    <h2 class="sec" style="font-size:24px">Частые вопросы</h2>
    {faqs.map(f => (
      <details class="gfaq"><summary>{f.q}</summary><p>{f.a}</p></details>
    ))}

    <p class="gdisc">Учебная информация, не финансовая консультация; экономия зависит от водителя и компании. Независимый брокер — сравниваем несколько компаний; покрытие, право на него, цена и доступность зависят от компании и полиса и доступны не всем. Смотрите также: <a href="/ru/fight-traffic-ticket">что делать со штрафом</a> · <a href="/ru/car-accident-checklist">чек-лист при ДТП</a> · <a href="/ru/auto-insurance">автострахование</a>.</p>

  </div></section>
</Base>

<style is:global>
  .guide{max-width:820px;padding-bottom:40px}
  .gcard{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:26px 28px;margin-bottom:18px}
  .gcard h2{font-size:21px;margin-bottom:12px}
  .gcard p{margin:10px 0;color:var(--ink)}
  .gitem{border-left:3px solid var(--accent);padding:2px 0 2px 14px;margin:14px 0}
  .gitem h3{font-size:16.5px;margin-bottom:4px}
  .gitem p{margin:0;color:var(--muted);font-size:15px}
  .gcard a{color:var(--blue);font-weight:600}
  .gcta{background:var(--blue-dark);color:#fff;text-align:center;padding:34px 28px}
  .gcta h3{color:#fff;font-size:23px}
  .gcta p{color:#fff;opacity:.88;max-width:560px;margin:10px auto 18px}
  .gphone{margin-top:14px !important;font-size:14px !important}
  .gfaq{background:#fff;border:1px solid var(--line);border-radius:14px;margin-bottom:8px;padding:0 18px}
  .gfaq summary{padding:14px 0;cursor:pointer;font-weight:700}
  .gfaq p{padding:0 0 16px;color:var(--muted)}
  .gdisc{color:var(--muted);font-size:13px;margin:24px 0 10px}
  .gdisc a{color:var(--blue)}
</style>
