---
import Base from '../../layouts/Base.astro';
import { contact } from '../../i18n/content-standalone.js';
import { UI } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'ru' }, props: { c: contact.ru, lang: 'ru' } },
  ];
}
const { c, lang } = Astro.props;
const t = UI[lang];
const phone = '+13102995555';
---
<Base title={c.metaTitle} description={c.metaDesc}>
  <section class="hero"><div class="wrap">
    <h1>{c.h1}</h1>
    <p class="sub">{c.sub}</p>
    <div class="ctas">
      <a class="btn btn-call btn-lg" href={`tel:${phone}`}>📞 {t.callNow}</a>
      <a class="btn btn-text btn-lg" href={`sms:${phone}`}>💬 {t.textUs}</a>
    </div>
  </div></section>

  <section><div class="wrap">
    <div class="grid grid-2">
      <div class="card">
        <h3>{c.reachTitle}</h3>
        <p style="margin-top:8px" set:html={c.reach}></p>
        <h3 style="margin-top:20px">{c.hoursTitle}</h3>
        <p style="margin-top:8px" set:html={c.hours}></p>
      </div>
      <div class="card" style="padding:0;overflow:hidden">
        <iframe title="CoverToday" width="100%" height="100%" style="min-height:340px;border:0" loading="lazy"
          src="https://www.google.com/maps?q=272+S+Rampart+Blvd,+Los+Angeles,+CA+90057&output=embed"></iframe>
      </div>
    </div>
  </div></section>
</Base>
