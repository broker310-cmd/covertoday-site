---
import Base from '../layouts/Base.astro';
const phone = '+13102995555';
---
<Base title="Careers — Join CoverToday Insurance" description="Join CoverToday Insurance, a growing bilingual (English/Russian) brokerage in Los Angeles. We're hiring licensed P&C agents and customer service reps. Email info@covertoday.com.">
  <section class="hero"><div class="wrap">
    <h1>Grow your insurance career with us.</h1>
    <p class="sub">We're a fast-growing, independent, bilingual brokerage in Los Angeles — and we're always looking for great people who put clients first.</p>
  </div></section>

  <section><div class="wrap" style="max-width:820px">
    <h2 class="sec">Why CoverToday</h2>
    <ul style="line-height:2;font-size:17px">
      <li>Independent shop — you can actually solve clients' problems across 40+ carriers.</li>
      <li>Warm leads and a modern tech stack (CRM, AI assistance) — less busywork, more selling.</li>
      <li>Bilingual English/Russian book of business with room to grow.</li>
      <li>Supportive, family-run team in Los Angeles.</li>
    </ul>

    <h2 class="sec">Roles we hire for</h2>
    <ul style="line-height:2;font-size:17px">
      <li><strong>Licensed P&C Insurance Agent</strong> (CA license required; bilingual EN/RU a plus)</li>
      <li><strong>Customer Service / Account Manager</strong> (COIs, endorsements, renewals)</li>
      <li><strong>Sales Development / Lead Intake</strong></li>
    </ul>

    <h2 class="sec">How to apply</h2>
    <p>Send your résumé and a short note about yourself to <a href="mailto:info@covertoday.com">info@covertoday.com</a>, or call us at (310) 299-5555. Tell us which role interests you and whether you hold a California insurance license.</p>

    <div class="card" style="padding:26px;margin-top:24px;text-align:center">
      <h2 style="margin-top:0">Ready to apply?</h2>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:10px">
        <a class="btn btn-call" href="mailto:info@covertoday.com">✉ Email your résumé</a>
        <a class="btn btn-ghost" href={`tel:${phone}`}>📞 (310) 299-5555</a>
      </div>
    </div>
  </div></section>
</Base>
