---
import Base from '../layouts/Base.astro';
const phone = '+13102995555';
---
<Base title="Get a Free Insurance Quote | CoverToday" description="Get a free quote for auto, SR-22, trucking, business or home insurance. We compare 40+ carriers. Russian-speaking agents. Call (310) 299-5555.">
  <section class="hero"><div class="wrap">
    <h1>Get your free quote</h1>
    <p class="sub">Tell us a little about you and we’ll find your lowest rate from 40+ carriers. Prefer to talk? Call or text — мы говорим по-русски.</p>
  </div></section>

  <section><div class="wrap" style="max-width:680px">
    <div class="card" style="padding:14px">
      <iframe
        src="https://api.leadconnectorhq.com/widget/form/uv5QnT4WcINhu1MBjjFe"
        style="width:100%;min-height:720px;border:none;border-radius:10px;background:#fff;display:block"
        id="inline-uv5QnT4WcINhu1MBjjFe"
        data-layout='{"id":"INLINE"}'
        data-trigger-type="alwaysShow"
        data-form-id="uv5QnT4WcINhu1MBjjFe"
        data-form-name="Get a Quote — CoverToday"
        data-height="720"
        data-deactivation-type="neverDeactivate"
        title="Get a Quote — CoverToday"
      ></iframe>
      <div style="margin-top:12px;font-size:13px;color:var(--muted);line-height:1.5">
        <p style="margin:0 0 8px"><strong>SMS consent &amp; disclosures.</strong> By checking the SMS consent box and submitting this form, you agree to receive text messages (SMS) and emails from CoverToday Insurance Agency, a DBA of Univision Insurance Services LLC (CA License #0K77310), at the phone number and email you provide. The consent box is unchecked by default and is not required to buy — consent is not a condition of purchase.</p>
        <p style="margin:0 0 8px"><strong>Message types:</strong> account and service notifications (quote follow-ups, appointment reminders, policy, renewal and document updates) and occasional promotional offers (rate reviews and discounts). <strong>Message frequency varies. Message and data rates may apply.</strong> Reply <strong>STOP</strong> to opt out or <strong>HELP</strong> for help.</p>
        <p style="margin:0">Your mobile information is never shared with or sold to third parties or affiliates for marketing purposes. See our <a href="/privacy-policy">Privacy Policy</a> and <a href="/sms-terms">SMS Terms</a>.</p>
      </div>
    </div>
    <p style="text-align:center;color:var(--muted);font-size:14px;margin-top:16px">
      Prefer to talk? Call or text <a href={`tel:${phone}`} style="color:var(--blue);font-weight:700">(310) 299-5555</a> — мы говорим по-русски.
    </p>
  </div></section>

  <script is:inline src="https://link.msgsndr.com/js/form_embed.js"></script>
</Base>
