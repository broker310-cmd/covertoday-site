---
import Base from '../layouts/Base.astro';

const faqs = [
  { q: 'Is minimum coverage the cheapest way to insure my car?', a: 'It has the lowest premium, but it is often the most expensive choice after an accident. California minimums (30/60/15 since 2025) run out fast in a real crash, and everything above them comes out of your pocket. The smarter play is trimming cost with discounts, deductibles, and carrier shopping — not by cutting protection.' },
  { q: 'Does my credit score affect my car insurance rate in California?', a: 'No. California is one of the few states that prohibits using credit history to price auto insurance. Your driving record, years licensed, annual mileage, and vehicle matter instead — which is why protecting your record (traffic school, safe driving) directly protects your rate.' },
  { q: 'How much does California’s Good Driver discount save?', a: 'By law (Proposition 103), qualifying drivers get at least 20% off. You generally qualify if you have been licensed for 3+ years and have no more than 1 point on your record. One at-fault accident or unmasked ticket can cost you this discount for years — often more money than the ticket itself.' },
  { q: 'What is the CLCA low-cost insurance program?', a: 'California’s Low Cost Automobile Insurance Program offers state-sponsored liability policies for income-eligible drivers with vehicles valued under $25,000. If your budget is tight, ask us about it or visit mylowcostauto.com — sometimes it is the right bridge, and sometimes a regular carrier actually beats it. We will tell you honestly which.' },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};

const groups = [
  { icon: '🇨🇦', t: 'Use your California rights', items: [
    { t: 'The 20% Good Driver discount — it’s the law', d: 'Proposition 103 guarantees at least 20% off for good drivers: generally 3+ years licensed and no more than 1 point. If you qualify and don’t see it, ask. Protecting this discount is the single biggest savings lever in California.' },
    { t: 'Your credit score can’t be used against you', d: 'California bans credit-based insurance pricing. Your driving record is what counts — so when a ticket is eligible for traffic school, taking it usually pays for itself by keeping the point masked from insurers.' },
    { t: 'CLCA — the state’s low-cost program', d: 'Income-eligible drivers with vehicles under $25,000 can get state-sponsored liability coverage (mylowcostauto.com). Worth checking if budget is the main constraint.' },
  ]},
  { icon: '🛒', t: 'Shop like a pro', items: [
    { t: 'Compare carriers — really compare', d: 'The same driver can be quoted wildly different prices by different carriers. As an independent broker we compare 15+ carriers in one pass — that is the whole point of a broker.' },
    { t: 'Re-shop at renewal and after life changes', d: 'Moved? Changed jobs or commute? Added years of clean driving? Carriers reward different profiles differently — a rate that was best last year often isn’t this year.' },
    { t: 'Never let coverage lapse', d: 'Even a few days’ gap flags you as high-risk and raises quotes across the market. If money is tight, downgrade — don’t cancel.' },
  ]},
  { icon: '⚙️', t: 'Tune the policy itself', items: [
    { t: 'Raise your deductibles', d: 'Going from a $500 to a $1,000 deductible typically cuts the collision/comprehensive portion noticeably. Just keep the difference in savings.' },
    { t: 'Drop collision on an old car', d: 'If the car is worth little more than the deductible plus a year of collision premium, full coverage may no longer make sense. We’ll do that math with you.' },
    { t: 'Bundle and pick payment discounts', d: 'Auto + renters/home bundles, pay-in-full, autopay, and paperless discounts are small individually but stack up.' },
  ]},
  { icon: '🚗', t: 'Match the policy to your life', items: [
    { t: 'Report lower mileage', d: 'Driving less than you did last year — new remote job, retired, moved closer? Annual mileage is a major California rating factor. Tell your insurer.' },
    { t: 'Student discounts', d: 'Good student discounts (usually a B average) and student-away-at-school discounts for kids at college without the car are commonly missed.' },
    { t: 'Mature driver course (55+)', d: 'Completing an approved mature driver improvement course earns a discount with many carriers.' },
  ]},
];
---
<Base
  title="How to Pay Less for Car Insurance in California — 12 Real Ways | CoverToday"
  description="California-specific ways to cut your car insurance cost: the 20% Good Driver law, credit ban, CLCA program, deductibles, bundling, mileage, and smart carrier shopping. EN & RU."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <section class="hero"><div class="wrap">
    <h1>Stop <span style="color:var(--accent)">overpaying</span> for car insurance.</h1>
    <p class="sub">Twelve ways Californians actually cut their premium — including three rights most drivers don't know they have. No gimmicks, no coverage-stripping.</p>
  </div></section>

  <section><div class="wrap guide">

    {groups.map(g => (
      <div class="gcard">
        <h2>{g.icon} {g.t}</h2>
        {g.items.map(it => (
          <div class="gitem">
            <h3>{it.t}</h3>
            <p>{it.d}</p>
          </div>
        ))}
      </div>
    ))}

    <div class="gcard">
      <h2>⚠️ One warning</h2>
      <p>Don't confuse a cheap premium with a good deal. California's minimum limits (30/60/15) are a legal floor, not a recommendation — in a serious accident they run out quickly and the rest comes out of your assets and wages. The goal is the <strong>right coverage at the lowest available price</strong>, not the least coverage.</p>
    </div>

    <div class="gcard gcta">
      <h3>Want us to run all twelve for you?</h3>
      <p>Send us your current policy — we'll check every discount you're missing, compare 15+ carriers, and tell you honestly if your current deal is already good. Free, in English or Russian.</p>
      <a class="btn btn-call btn-lg" href="/quote">Compare my rate</a>
      <p class="gphone">(310) 299-5555 · covertoday.com/quote</p>
    </div>

    <h2 class="sec" style="font-size:24px">Frequently asked questions</h2>
    {faqs.map(f => (
      <details class="gfaq"><summary>{f.q}</summary><p>{f.a}</p></details>
    ))}

    <p class="gdisc">Educational information, not financial advice; savings vary by driver and carrier. Independent broker — we compare multiple carriers; coverage, eligibility, price and availability vary and may not be available to everyone. Related: <a href="/fight-traffic-ticket">what to do about a traffic ticket</a> · <a href="/car-accident-checklist">accident checklist</a> · <a href="/auto-insurance">auto insurance</a>.</p>

  </div></section>
</Base>

<style is:global>
  .guide{max-width:820px;padding-bottom:40px}
  .gcard{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:26px 28px;margin-bottom:18px}
  .gcard h2{font-size:21px;margin-bottom:12px}
  .gcard p{margin:10px 0;color:var(--ink)}
  .gitem{border-left:3px solid var(--accent);padding:2px 0 2px 14px;margin:14px 0}
  .gitem h3{font-size:16.5px;margin-bottom:4px}
  .gitem p{margin:0;color:var(--muted);font-size:15px}
  .gcard a{color:var(--blue);font-weight:600}
  .gcta{background:var(--blue-dark);color:#fff;text-align:center;padding:34px 28px}
  .gcta h3{color:#fff;font-size:23px}
  .gcta p{color:#fff;opacity:.88;max-width:560px;margin:10px auto 18px}
  .gphone{margin-top:14px !important;font-size:14px !important}
  .gfaq{background:#fff;border:1px solid var(--line);border-radius:14px;margin-bottom:8px;padding:0 18px}
  .gfaq summary{padding:14px 0;cursor:pointer;font-weight:700}
  .gfaq p{padding:0 0 16px;color:var(--muted)}
  .gdisc{color:var(--muted);font-size:13px;margin:24px 0 10px}
  .gdisc a{color:var(--blue)}
</style>
