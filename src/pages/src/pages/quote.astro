---
import Base from '../layouts/Base.astro';
const phone = '+13102995555';
---
<Base title="Get a Free Insurance Quote | CoverToday" description="Get a free quote for auto, SR-22, trucking, business or home insurance. We compare 40+ carriers. Russian-speaking agents. Call (310) 299-5555.">
  <section class="hero"><div class="wrap">
    <h1>Get your free quote</h1>
    <p class="sub">Tell us a little about you and we’ll find your lowest rate from 40+ carriers. Prefer to talk? Call or text — мы говорим по-русски.</p>
  </div></section>

  <section><div class="wrap" style="max-width:640px">
    <form class="card" style="padding:30px" action="https://formsubmit.co/info@covertoday.com" method="POST">
      <h2 class="sec" style="font-size:24px">Request a quote</h2>

      <!-- FormSubmit settings -->
      <input type="hidden" name="_subject" value="New quote request from covertoday.com" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_next" value="https://covertoday-site.vercel.app/quote?sent=1" />
      <input type="text" name="_honey" style="display:none" />

      <label>Full name</label>
      <input name="name" required placeholder="John Doe" />
      <label>Phone</label>
      <input name="phone" type="tel" required placeholder="(310) 555-0123" />
      <label>ZIP code</label>
      <input name="zip" required placeholder="90057" />
      <label>What do you need?</label>
      <select name="line">
        <option>Auto insurance</option>
        <option>SR-22</option>
        <option>Commercial trucking / DOT-MC</option>
        <option>Business insurance</option>
        <option>Home / renters</option>
        <option>Rideshare / Uber / TCP</option>
        <option>Other</option>
      </select>
      <button class="btn btn-call" type="submit" style="width:100%;justify-content:center;margin-top:18px">Get my quote →</button>
      <p style="text-align:center;color:var(--muted);font-size:13px;margin-top:10px">Or call us directly at (310) 299-5555</p>
    </form>
  </div></section>

  <style>
    form label{display:block;font-size:13px;font-weight:700;color:var(--muted);margin:14px 0 5px}
    form input,form select{width:100%;padding:12px 14px;border:1.5px solid var(--line);border-radius:10px;font-size:15px;font-family:inherit}
    form input:focus,form select:focus{outline:none;border-color:var(--blue)}
    #sent-banner{background:#e9f9ef;border:1px solid #1f9d57;color:#0c6b39;border-radius:12px;padding:14px 18px;margin:0 auto 18px;max-width:640px;font-weight:600;text-align:center}
  </style>

  <script is:inline>
    if (location.search.includes('sent=1')) {
      const b = document.createElement('div');
      b.id = 'sent-banner';
      b.textContent = '✓ Thank you! Your request was sent. We’ll call or text you shortly.';
      const form = document.querySelector('form');
      form.parentNode.insertBefore(b, form);
      form.reset();
    }
  </script>
</Base>
